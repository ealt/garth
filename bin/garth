#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  LINK_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$LINK_DIR/$SOURCE_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
GARTH_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$GARTH_ROOT/lib/common.sh"
source "$GARTH_ROOT/lib/git.sh"
source "$GARTH_ROOT/lib/secrets.sh"
source "$GARTH_ROOT/lib/github-app.sh"
source "$GARTH_ROOT/lib/container.sh"
source "$GARTH_ROOT/lib/zellij.sh"
source "$GARTH_ROOT/lib/workspace.sh"

garth_install_cleanup_trap

GARTH_STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/garth"
# Standalone repo default: keep config in repo root unless explicitly overridden.
GARTH_CONFIG_PATH="${GARTH_CONFIG_PATH:-$GARTH_ROOT/config.toml}"
GARTH_BIN_PATH="$SCRIPT_DIR/garth"

if garth_is_macos && [[ -x "/opt/homebrew/bin/python3" ]]; then
  export PATH="/opt/homebrew/bin:$PATH"
fi

usage() {
  cat << 'USAGE'
Usage: garth <command> [options]

Commands:
  boot <dir>                      Launch workspace (zellij + agents + tools)
  worktree <repo-dir> <branch>   Create worktree, then boot
  agent <dir> <name>             Run one agent in docker or host mode
  token <dir>                    Mint a GitHub App installation token
  doctor [--repo <dir>]          Diagnose local setup and auth health
  status                          Show active garth sessions
  stop <session>|--repo <dir>|--all
                                  Stop sessions and containers
  setup                           First-time setup helper

Run 'garth <command> --help' for command-specific options.
USAGE
}

ensure_state_root() {
  mkdir -p "$GARTH_STATE_ROOT/sessions"
  chmod 700 "$GARTH_STATE_ROOT" "$GARTH_STATE_ROOT/sessions"
}

config_env() {
  garth_python "$GARTH_ROOT/lib/config-parser.py" env "$GARTH_CONFIG_PATH"
}

load_config() {
  [[ -f "$GARTH_CONFIG_PATH" ]] || garth_die "Config not found: $GARTH_CONFIG_PATH" 1
  eval "$(config_env)"
}

agent_exists() {
  local agent="$1"
  local key
  key=$(garth_agent_key "$agent")
  local var="GARTH_AGENT_${key}_BASE_COMMAND"
  [[ -n "${!var:-}" ]]
}

csv_to_array() {
  local csv="$1"
  if [[ -z "$csv" ]]; then
    return 0
  fi
  IFS=',' read -r -a _GARTH_ARRAY_OUT <<< "$csv"
}

csv_contains_token() {
  local csv="$1"
  local token="$2"
  [[ -n "$csv" && -n "$token" ]] || return 1
  case ",$csv," in
    *",$token,"*) return 0 ;;
    *) return 1 ;;
  esac
}

resolve_agents() {
  local requested_csv="$1"
  local csv="$requested_csv"
  if [[ -z "$csv" ]]; then
    csv="$GARTH_DEFAULTS_AGENTS_CSV"
  fi

  csv_to_array "$csv"
  GARTH_SELECTED_AGENTS=("${_GARTH_ARRAY_OUT[@]:-}")
  [[ ${#GARTH_SELECTED_AGENTS[@]} -gt 0 ]] || garth_die "No agents selected" 1

  local agent
  for agent in "${GARTH_SELECTED_AGENTS[@]}"; do
    agent="${agent// /}"
    [[ -n "$agent" ]] || continue
    agent_exists "$agent" || garth_die "Unknown agent in selection: $agent" 1
  done
}

session_dir_for() {
  local session="$1"
  echo "$GARTH_STATE_ROOT/sessions/$session"
}

write_state_value() {
  local session_dir="$1"
  local key="$2"
  local value="$3"
  printf '%s\n' "$value" > "$session_dir/$key"
}

read_state_value() {
  local session_dir="$1"
  local key="$2"
  if [[ -f "$session_dir/$key" ]]; then
    cat "$session_dir/$key"
  fi
}

token_cache_dir() {
  echo "$GARTH_STATE_ROOT/token-cache"
}

token_cache_file_for_owner_repo() {
  local owner_repo="$1"
  local key
  key=$(echo "$owner_repo" | sed -E 's/[^A-Za-z0-9._-]+/_/g')
  echo "$(token_cache_dir)/${key}.tsv"
}

garth_read_cached_token_for_owner_repo() {
  local owner_repo="$1"
  local cache_file
  cache_file=$(token_cache_file_for_owner_repo "$owner_repo")
  [[ -f "$cache_file" ]] || return 1

  local token expires_at expires_epoch installation_id
  IFS=$'\t' read -r token expires_at expires_epoch installation_id < "$cache_file" || return 1
  [[ -n "$token" && -n "$expires_at" && -n "$expires_epoch" ]] || return 1
  [[ "$expires_epoch" =~ ^[0-9]+$ ]] || return 1

  local now min_ttl
  now=$(garth_now_epoch)
  min_ttl="${GARTH_TOKEN_CACHE_MIN_TTL_SECONDS:-}"
  if [[ -z "$min_ttl" ]]; then
    if [[ -n "${GARTH_TOKEN_REFRESH_LEAD_TIME:-}" ]]; then
      local lead_seconds
      lead_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_LEAD_TIME" 2>/dev/null || true)
      if [[ "$lead_seconds" =~ ^[0-9]+$ ]] && (( lead_seconds > 0 )); then
        min_ttl="$lead_seconds"
      fi
    fi
  fi
  if [[ -z "$min_ttl" || ! "$min_ttl" =~ ^[0-9]+$ ]]; then
    min_ttl=900
  fi
  if (( expires_epoch <= now + min_ttl )); then
    return 1
  fi

  printf '%s\t%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" "$owner_repo"
}

garth_write_cached_token_for_owner_repo() {
  local owner_repo="$1"
  local token="$2"
  local expires_at="$3"
  local expires_epoch="$4"
  local installation_id="$5"
  local cache_dir cache_file tmp_file

  cache_dir=$(token_cache_dir)
  mkdir -p "$cache_dir"
  chmod 700 "$cache_dir"

  cache_file=$(token_cache_file_for_owner_repo "$owner_repo")
  tmp_file="${cache_file}.tmp.$$"
  umask 077
  printf '%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" > "$tmp_file"
  chmod 600 "$tmp_file"
  mv "$tmp_file" "$cache_file"
}

mint_token_for_repo() {
  local repo_root="$1"
  local remote_url owner_repo

  remote_url=$(garth_git_remote_url "$repo_root" "origin")
  owner_repo=$(garth_git_owner_repo_from_remote "$remote_url") || \
    garth_die "Unsupported remote URL format (expected GitHub): $remote_url" 1

  local cached
  if cached=$(garth_read_cached_token_for_owner_repo "$owner_repo" 2>/dev/null); then
    printf '%s\n' "$cached"
    return 0
  fi

  # Ensure interactive signin (when needed) happens in the parent shell.
  garth_require_op

  local minted
  minted=$(garth_github_mint_installation_token "$owner_repo") || \
    garth_die "Failed to mint GitHub token. Check 1Password sign-in and GitHub App config." 3

  local token expires_at installation_id
  IFS=$'\t' read -r token expires_at installation_id <<< "$minted"
  [[ -n "$token" && -n "$expires_at" ]] || garth_die "Failed to mint GitHub token" 3

  local expires_epoch
  expires_epoch=$(garth_iso8601_to_epoch "$expires_at")
  garth_write_cached_token_for_owner_repo "$owner_repo" "$token" "$expires_at" "$expires_epoch" "$installation_id"

  printf '%s\t%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" "$owner_repo"
}

compute_profile_name() {
  local repo_name="$1"
  local branch="$2"
  local slug
  slug=$(garth_slugify_branch "$branch")
  echo "${repo_name}-${slug}"
}

sleep_with_session_guard() {
  local seconds="$1"
  local session_dir="$2"
  local i
  for ((i = 0; i < seconds; i++)); do
    [[ -f "$session_dir/active" ]] || return 1
    sleep 1
  done
  return 0
}

garth_is_sensitive_changed_path() {
  local path="$1"
  case "$path" in
    .git/hooks/*|.git/config|.github/*|.github/workflows/*|Makefile|*.sh|.circleci/*|.gitlab-ci.yml|Jenkinsfile)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

garth_post_session_report() {
  local session="$1"
  local session_dir="$2"
  local worktree="$3"

  [[ -n "$worktree" ]] || return 0
  if ! git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  local diff_stat
  diff_stat=$(git -C "$worktree" diff --stat 2>/dev/null || true)
  if [[ -n "$diff_stat" ]]; then
    garth_log_info "Post-session diff summary ($session):"
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      echo "  $line"
    done <<< "$diff_stat"
  fi

  local -a changed_paths=()
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    changed_paths+=("$path")
  done < <(
    {
      git -C "$worktree" diff --name-only
      git -C "$worktree" diff --cached --name-only
      git -C "$worktree" ls-files --others --exclude-standard
    } 2>/dev/null | sed '/^$/d' | sort -u
  )

  local -a sensitive_paths=()
  local path
  for path in "${changed_paths[@]:-}"; do
    if garth_is_sensitive_changed_path "$path"; then
      sensitive_paths+=("$path")
    fi
  done

  if [[ ${#sensitive_paths[@]} -gt 0 ]]; then
    local sensitive_csv
    sensitive_csv=$(garth_join_by "," "${sensitive_paths[@]}")
    garth_log_warn "Sensitive paths changed in session '$session': $sensitive_csv"
    garth_audit_log "$session_dir" "post_session_change_report" \
      "session=$session" \
      "worktree=$worktree" \
      "sensitive_paths_csv=$sensitive_csv" \
      "sensitive_count=${#sensitive_paths[@]}"
  else
    garth_audit_log "$session_dir" "post_session_change_report" \
      "session=$session" \
      "worktree=$worktree" \
      "sensitive_count=0"
  fi
}

cmd_boot() {
  local dir=""
  local agents_csv=""
  local auth_passthrough_csv=""
  local network=""
  local sandbox=""
  local workspace=""
  local safety_mode=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agents)
        agents_csv="$2"
        shift 2
        ;;
      --auth-passthrough)
        auth_passthrough_csv="$2"
        shift 2
        ;;
      --network)
        network="$2"
        shift 2
        ;;
      --sandbox)
        sandbox="$2"
        shift 2
        ;;
      --no-sandbox)
        sandbox="none"
        shift
        ;;
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --safety)
        safety_mode="$2"
        shift 2
        ;;
      --dry-run)
        GARTH_DRY_RUN=true
        shift
        ;;
      --yes|-y)
        GARTH_YES=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth boot <dir> [options]

Options:
  --agents <a,b>              Comma-separated agents
  --auth-passthrough <a,b>    Docker auth passthrough for selected agents (opt-in, reduced isolation)
  --sandbox docker|none       Runtime sandbox mode
  --no-sandbox                Alias for --sandbox none
  --network bridge|none       Docker network mode
  --workspace <N|auto>        Move windows to AeroSpace workspace N, or auto-select next (max+1)
  --safety safe|permissive    Agent argument preset
  --dry-run                   Print commands without executing
  --yes, -y                   Auto-confirm prompts
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for boot: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done

  [[ -n "$dir" ]] || garth_die "boot requires <dir>" 1

  load_config
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    ensure_state_root
  fi

  sandbox="${sandbox:-$GARTH_DEFAULTS_SANDBOX}"
  network="${network:-$GARTH_DEFAULTS_NETWORK}"
  workspace="${workspace:-$GARTH_DEFAULTS_WORKSPACE}"
  safety_mode="${safety_mode:-$GARTH_DEFAULTS_SAFETY_MODE}"
  auth_passthrough_csv="${auth_passthrough_csv:-$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV}"

  csv_to_array "$auth_passthrough_csv"
  local normalized_passthrough=()
  local passthrough_agent
  for passthrough_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
    passthrough_agent="${passthrough_agent// /}"
    [[ -n "$passthrough_agent" ]] || continue
    normalized_passthrough+=("$passthrough_agent")
  done
  auth_passthrough_csv=$(garth_join_by "," "${normalized_passthrough[@]:-}")

  [[ "$sandbox" == "docker" || "$sandbox" == "none" ]] || garth_die "Invalid sandbox mode: $sandbox" 1
  [[ "$network" == "bridge" || "$network" == "none" ]] || garth_die "Invalid network mode: $network" 1
  [[ "$safety_mode" == "safe" || "$safety_mode" == "permissive" ]] || garth_die "Invalid safety mode: $safety_mode" 1

  resolve_agents "$agents_csv"

  if [[ "$sandbox" == "docker" && -n "$auth_passthrough_csv" ]]; then
    garth_log_warn "Docker auth passthrough is enabled for: $auth_passthrough_csv"
    garth_log_warn "This weakens isolation by exposing local CLI auth state to containers."
  fi

  if [[ "$GARTH_DRY_RUN" != "true" && "$sandbox" == "docker" ]]; then
    garth_require_cmd docker
    local image_agent
    for image_agent in "${GARTH_SELECTED_AGENTS[@]}"; do
      garth_ensure_agent_image_ready "$image_agent" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" || \
        garth_die "Docker image setup failed for agent '$image_agent'" 1
    done
  fi
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_require_cmd zellij
  fi

  local abs_dir repo_root branch repo_name session session_dir
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1
  branch=$(garth_git_current_branch "$repo_root")
  repo_name=$(garth_git_repo_name "$repo_root")
  session=$(garth_git_session_name "$repo_name" "$branch")
  if [[ "$(garth_zellij_session_state "$session")" != "missing" ]]; then
    local base_session="$session"
    local n=2
    while [[ "$(garth_zellij_session_state "${base_session}-${n}")" != "missing" ]]; do
      n=$((n + 1))
    done
    session="${base_session}-${n}"
    garth_log_warn "Reusing session name is unavailable; using $session"
  fi
  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    session_dir=$(garth_make_temp_dir)
  else
    session_dir=$(session_dir_for "$session")

    if [[ -d "$session_dir" ]]; then
      if [[ -f "$session_dir/active" ]]; then
        local zellij_state
        zellij_state=$(garth_zellij_session_state "$session")
        if [[ "$zellij_state" == "running" ]]; then
          garth_die "Session already exists: $session (use 'garth stop $session' first)" 1
        fi
        garth_log_warn "Found stale active state for $session; cleaning it up"
        stop_session "$session"
      else
        garth_log_warn "Found stale session directory for $session; removing it"
        rm -rf "$session_dir"
      fi
    fi

    mkdir -p "$session_dir"
    chmod 700 "$session_dir"
  fi

  local token expires_at expires_epoch installation_id owner_repo
  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    owner_repo=$(garth_git_owner_repo_from_remote "$(garth_git_remote_url "$repo_root" origin)") || \
      garth_die "Unsupported remote URL format (expected GitHub)" 1
    token="GARTH_DRY_RUN_TOKEN"
    expires_at="2099-01-01T00:00:00Z"
    expires_epoch="4070908800"
    installation_id="dry-run"
  else
    local minted_file
    minted_file=$(mktemp "${TMPDIR:-/tmp}/garth-minted-token.XXXXXX") || return 1
    garth_register_cleanup_path "$minted_file"
    if ! mint_token_for_repo "$repo_root" > "$minted_file"; then
      garth_audit_log "$session_dir" "token_mint_failure" \
        "session=$session" \
        "repo_root=$repo_root"
      return 3
    fi
    IFS=$'\t' read -r token expires_at expires_epoch installation_id owner_repo < "$minted_file"
  fi

  local token_file
  token_file=$(garth_write_token_file "$session_dir" "$token")
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_audit_log "$session_dir" "token_mint_success" \
      "session=$session" \
      "owner_repo=$owner_repo" \
      "installation_id=$installation_id" \
      "token=$token" \
      "token_expires_at=$expires_at"
  fi

  local agent
  for agent in "${GARTH_SELECTED_AGENTS[@]}"; do
    if [[ "$GARTH_DRY_RUN" == "true" ]]; then
      local api_key_env env_file
      api_key_env=$(garth_agent_field "$agent" "API_KEY_ENV")
      env_file="$session_dir/agent-${agent}.env"
      umask 077
      {
        printf 'TERM=xterm-256color\n'
        printf 'GARTH_GITHUB_TOKEN_FILE=/run/garth/github_token\n'
        printf '%s=%s\n' "$api_key_env" "GARTH_DRY_RUN_API_KEY"
      } > "$env_file"
      chmod 600 "$env_file"
    else
      local require_api_key=true
      if [[ "$sandbox" == "none" ]] || csv_contains_token "$auth_passthrough_csv" "$agent"; then
        require_api_key=false
      fi
      garth_prepare_agent_env_file "$session_dir" "$agent" "$require_api_key" >/dev/null || return 3
    fi
  done

  local layout_file="$session_dir/layout.kdl"
  garth_generate_zellij_layout "$layout_file" "$abs_dir" "$session" "$repo_root" "$session_dir" "$network" \
    "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" "$safety_mode" "$sandbox" "$auth_passthrough_csv" "${GARTH_SELECTED_AGENTS[@]}"

  local agents_csv_effective
  agents_csv_effective=$(garth_join_by "," "${GARTH_SELECTED_AGENTS[@]}")

  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    garth_log_info "[dry-run] skipping persistent session state writes"
  else
    write_state_value "$session_dir" "active" "1"
    write_state_value "$session_dir" "repo_root" "$repo_root"
    write_state_value "$session_dir" "worktree" "$abs_dir"
    write_state_value "$session_dir" "branch" "$branch"
    write_state_value "$session_dir" "owner_repo" "$owner_repo"
    write_state_value "$session_dir" "agents_csv" "$agents_csv_effective"
    write_state_value "$session_dir" "token_state" "ok"
    write_state_value "$session_dir" "token_expires_at" "$expires_at"
    write_state_value "$session_dir" "token_expires_epoch" "$expires_epoch"
    write_state_value "$session_dir" "started_epoch" "$(garth_now_epoch)"
    write_state_value "$session_dir" "sandbox" "$sandbox"
    write_state_value "$session_dir" "network" "$network"
    write_state_value "$session_dir" "safety_mode" "$safety_mode"
    write_state_value "$session_dir" "installation_id" "$installation_id"
    write_state_value "$session_dir" "token_file" "$token_file"
    garth_audit_log "$session_dir" "session_start" \
      "session=$session" \
      "repo_root=$repo_root" \
      "worktree=$abs_dir" \
      "branch=$branch" \
      "agents=$agents_csv_effective" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode" \
      "owner_repo=$owner_repo" \
      "installation_id=$installation_id" \
      "token_expires_at=$expires_at"
    if [[ -n "$auth_passthrough_csv" ]]; then
      garth_audit_log "$session_dir" "auth_passthrough_enabled" \
        "session=$session" \
        "auth_passthrough=$auth_passthrough_csv"
    fi

    if [[ "$GARTH_TOKEN_REFRESH_ENABLED" == "true" ]]; then
      "$GARTH_BIN_PATH" internal-refresh \
        --repo-root "$repo_root" \
        --session "$session" \
        --session-dir "$session_dir" >/dev/null 2>&1 &
      write_state_value "$session_dir" "refresher_pid" "$!"
      garth_audit_log "$session_dir" "token_refresher_started" \
        "session=$session" \
        "refresher_pid=$!"
    fi
  fi

  local github_url
  github_url=$(garth_git_https_url_from_remote "$(garth_git_remote_url "$repo_root" origin)")

  local profile_name
  profile_name=$(compute_profile_name "$repo_name" "$branch")

  if [[ "${GARTH_SKIP_GUI:-false}" == "true" ]]; then
    garth_log_warn "GARTH_SKIP_GUI=true; skipping workspace/Cursor/Chrome launch steps"
  else
    garth_move_windows_to_workspace "$workspace"
    if [[ "${GARTH_SKIP_CURSOR:-false}" == "true" ]]; then
      garth_log_warn "GARTH_SKIP_CURSOR=true; skipping Cursor launch steps"
    else
      garth_configure_cursor_terminal_bridge "$abs_dir" "$sandbox"
      garth_launch_cursor "$abs_dir"
    fi
    if [[ "${GARTH_SKIP_CHROME:-false}" == "true" ]]; then
      garth_log_warn "GARTH_SKIP_CHROME=true; skipping Chrome launch"
    else
      garth_launch_chrome_profile "$GARTH_CHROME_PROFILES_DIR" "$profile_name" "$github_url"
    fi
  fi

  garth_log_info "Starting zellij session: $session"
  if ! garth_zellij_launch "$session" "$layout_file"; then
    garth_audit_log "$session_dir" "container_start_failure" \
      "session=$session" \
      "reason=zellij_launch_failed"
    return 1
  fi
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_audit_log "$session_dir" "container_start" \
      "session=$session" \
      "agents=$agents_csv_effective" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode"
  fi

  # If session no longer exists after detach/exit, clean stale session state.
  if [[ "$GARTH_DRY_RUN" != "true" && "$GARTH_ZELLIJ_LAUNCH_ASYNC" == "true" ]]; then
    local wait_s
    for wait_s in 1 2 3 4 5; do
      if garth_zellij_list_sessions | grep -qx "$session"; then
        break
      fi
      sleep 1
    done
  fi

  if [[ "$GARTH_DRY_RUN" != "true" ]] && ! garth_zellij_list_sessions | grep -qx "$session"; then
    garth_log_warn "zellij session did not start: $session"
    garth_log_warn "If your terminal launcher failed, run manually:"
    if garth_zellij_session_exists "$session"; then
      garth_log_warn "  zellij attach \"$session\""
    else
      garth_log_warn "  zellij -s \"$session\" --new-session-with-layout \"$layout_file\""
    fi
    garth_audit_log "$session_dir" "session_start_failure" \
      "session=$session" \
      "reason=session_not_running_after_launch"
    "$GARTH_BIN_PATH" stop "$session" --yes >/dev/null 2>&1 || true
  fi
}

cmd_worktree() {
  local repo_dir=""
  local branch=""
  local from_ref="origin/main"
  local forward=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)
        from_ref="$2"
        shift 2
        ;;
      --dry-run|--yes|-y|--agents|--auth-passthrough|--sandbox|--no-sandbox|--network|--workspace|--safety)
        forward+=("$1")
        if [[ "$1" == "--dry-run" || "$1" == "--no-sandbox" || "$1" == "--yes" || "$1" == "-y" ]]; then
          shift
        else
          forward+=("$2")
          shift 2
        fi
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth worktree <repo-dir> <branch> [--from <ref>] [boot flags...]
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for worktree: $1" 1
        ;;
      *)
        if [[ -z "$repo_dir" ]]; then
          repo_dir="$1"
        elif [[ -z "$branch" ]]; then
          branch="$1"
        else
          forward+=("$1")
        fi
        shift
        ;;
    esac
  done

  [[ -n "$repo_dir" && -n "$branch" ]] || garth_die "worktree requires <repo-dir> <branch>" 1

  local repo_root
  repo_root=$(garth_git_repo_root "$repo_dir") || garth_die "Not inside a git repo: $repo_dir" 1

  local wt_path
  wt_path=$(garth_git_create_worktree "$repo_root" "$branch" "$from_ref")
  garth_log_success "Created worktree: $wt_path"

  "$GARTH_BIN_PATH" boot "$wt_path" "${forward[@]}"
}

cmd_agent() {
  local dir=""
  local agent=""
  local auth_passthrough_csv=""
  local sandbox=""
  local network=""
  local safety_mode=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sandbox)
        sandbox="$2"
        shift 2
        ;;
      --auth-passthrough)
        auth_passthrough_csv="$2"
        shift 2
        ;;
      --network)
        network="$2"
        shift 2
        ;;
      --safety)
        safety_mode="$2"
        shift 2
        ;;
      --dry-run)
        GARTH_DRY_RUN=true
        shift
        ;;
      --yes|-y)
        GARTH_YES=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth agent <dir> <name> [--sandbox docker|none] [--network bridge|none] [--safety safe|permissive]
       [--auth-passthrough <a,b>]
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for agent: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
        elif [[ -z "$agent" ]]; then
          agent="$1"
        else
          garth_die "Unexpected argument: $1" 1
        fi
        shift
        ;;
    esac
  done

  [[ -n "$dir" && -n "$agent" ]] || garth_die "agent requires <dir> <name>" 1

  load_config
  auth_passthrough_csv="${auth_passthrough_csv:-$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV}"
  csv_to_array "$auth_passthrough_csv"
  local normalized_passthrough=()
  local passthrough_agent
  for passthrough_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
    passthrough_agent="${passthrough_agent// /}"
    [[ -n "$passthrough_agent" ]] || continue
    normalized_passthrough+=("$passthrough_agent")
  done
  auth_passthrough_csv=$(garth_join_by "," "${normalized_passthrough[@]:-}")
  sandbox="${sandbox:-$GARTH_DEFAULTS_SANDBOX}"
  network="${network:-$GARTH_DEFAULTS_NETWORK}"
  safety_mode="${safety_mode:-$GARTH_DEFAULTS_SAFETY_MODE}"

  if [[ "$sandbox" == "docker" && -n "$auth_passthrough_csv" ]]; then
    garth_log_warn "Docker auth passthrough is enabled for: $auth_passthrough_csv"
    garth_log_warn "This weakens isolation by exposing local CLI auth state to containers."
  fi

  agent_exists "$agent" || garth_die "Unknown agent: $agent" 1

  local abs_dir repo_root branch repo_name session
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1
  branch=$(garth_git_current_branch "$repo_root")
  repo_name=$(garth_git_repo_name "$repo_root")
  session="$(garth_git_session_name "$repo_name" "$branch")-adhoc"

  local tmp_dir
  tmp_dir=$(garth_make_temp_dir)

  local token expires_at expires_epoch installation_id owner_repo
  local minted_file
  minted_file=$(mktemp "${TMPDIR:-/tmp}/garth-minted-token.XXXXXX") || return 1
  garth_register_cleanup_path "$minted_file"
  mint_token_for_repo "$repo_root" > "$minted_file" || return 3
  IFS=$'\t' read -r token expires_at expires_epoch installation_id owner_repo < "$minted_file"
  garth_write_token_file "$tmp_dir" "$token" >/dev/null
  local require_api_key=true
  if [[ "$sandbox" == "none" ]] || csv_contains_token "$auth_passthrough_csv" "$agent"; then
    require_api_key=false
  fi
  garth_prepare_agent_env_file "$tmp_dir" "$agent" "$require_api_key" >/dev/null || return 3

  if [[ "$sandbox" == "none" ]]; then
    local cmd
    cmd=$(garth_agent_command_string "$agent" "$safety_mode")
    local env_file="$tmp_dir/agent-${agent}.env"
    garth_log_warn "Running without sandbox; agent has host access"
    if [[ "$GARTH_DRY_RUN" == "true" ]]; then
      echo "[dry-run] source $env_file && export GITHUB_TOKEN=... && $cmd"
      return 0
    fi
    local rc=0
    (
      cd "$abs_dir"
      set -a
      source "$env_file"
      set +a
      export GITHUB_TOKEN
      GITHUB_TOKEN=$(cat "$tmp_dir/github_token")
      bash -lc "$cmd"
    ) || rc=$?
    if ((rc != 0)); then
      garth_audit_log "$tmp_dir" "agent_exit_nonzero" \
        "agent=$agent" \
        "repo_root=$repo_root" \
        "worktree=$abs_dir" \
        "sandbox=$sandbox" \
        "network=$network" \
        "safety_mode=$safety_mode" \
        "exit_code=$rc"
      return "$rc"
    fi
    garth_audit_log "$tmp_dir" "agent_exit" \
      "agent=$agent" \
      "repo_root=$repo_root" \
      "worktree=$abs_dir" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode" \
      "exit_code=0"
    return 0
  fi

  garth_require_cmd docker
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_ensure_agent_image_ready "$agent" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" || \
      garth_die "Docker image setup failed for agent '$agent'" 1
  fi
  local auth_passthrough_enabled=false
  if csv_contains_token "$auth_passthrough_csv" "$agent"; then
    auth_passthrough_enabled=true
  fi
  local -a args=()
  local arg
  while IFS= read -r arg; do
    args+=("$arg")
  done < <(garth_container_args_lines "$session" "$repo_root" "$abs_dir" "$agent" "$tmp_dir/agent-${agent}.env" "$tmp_dir" "$network" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" "$safety_mode" "$auth_passthrough_enabled")

  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    echo "docker ${args[*]}"
    return 0
  fi

  local docker_rc=0
  docker "${args[@]}" || docker_rc=$?
  if ((docker_rc != 0)); then
    garth_audit_log "$tmp_dir" "agent_exit_nonzero" \
      "agent=$agent" \
      "repo_root=$repo_root" \
      "worktree=$abs_dir" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode" \
      "exit_code=$docker_rc"
    return "$docker_rc"
  fi
  garth_audit_log "$tmp_dir" "agent_exit" \
    "agent=$agent" \
    "repo_root=$repo_root" \
    "worktree=$abs_dir" \
    "sandbox=$sandbox" \
    "network=$network" \
    "safety_mode=$safety_mode" \
    "exit_code=0"
}

cmd_token() {
  local dir=""
  local machine=false
  local write_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --machine)
        machine=true
        shift
        ;;
      --write-file)
        write_file="$2"
        shift 2
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth token <dir> [--machine] [--write-file <path>]
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for token: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done

  [[ -n "$dir" ]] || garth_die "token requires <dir>" 1

  load_config

  local abs_dir repo_root token expires_at expires_epoch installation_id owner_repo
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1
  local minted_file
  minted_file=$(mktemp "${TMPDIR:-/tmp}/garth-minted-token.XXXXXX") || return 1
  garth_register_cleanup_path "$minted_file"
  mint_token_for_repo "$repo_root" > "$minted_file" || return 3
  IFS=$'\t' read -r token expires_at expires_epoch installation_id owner_repo < "$minted_file"

  if [[ -n "$write_file" ]]; then
    mkdir -p "$(dirname "$write_file")"
    umask 077
    printf '%s\n' "$token" > "$write_file"
    chmod 600 "$write_file"
  fi

  if [[ "$machine" == "true" ]]; then
    printf '%s\t%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" "$owner_repo"
  else
    printf '%s\n' "$token"
  fi
}

human_uptime() {
  local seconds="$1"
  if ((seconds < 60)); then
    echo "${seconds}s"
  elif ((seconds < 3600)); then
    echo "$((seconds / 60))m"
  else
    echo "$((seconds / 3600))h"
  fi
}

garth_docker_image_state() {
  local image_tag="$1"
  local err_file
  err_file=$(mktemp "${TMPDIR:-/tmp}/garth-docker-inspect.XXXXXX") || {
    echo "unavailable:failed to create temp file"
    return 0
  }
  garth_register_cleanup_path "$err_file"

  if docker image inspect "$image_tag" >/dev/null 2>"$err_file"; then
    rm -f "$err_file"
    echo "present"
    return 0
  fi

  local err_msg
  err_msg=$(tr '\n' ' ' < "$err_file" | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')
  rm -f "$err_file"

  if [[ "$err_msg" =~ [Nn]o\ such\ image ]] || [[ "$err_msg" =~ [Nn]ot\ found ]]; then
    echo "missing"
    return 0
  fi

  echo "unavailable:${err_msg:-docker inspect failed}"
}

count_session_containers() {
  local session="$1"
  if ! command -v docker >/dev/null 2>&1; then
    echo "0"
    return 0
  fi
  docker ps -q --filter "label=garth.session=$session" | wc -l | tr -d ' '
}

cmd_status() {
  local as_json=false
  if [[ "${1:-}" == "--json" ]]; then
    as_json=true
  elif [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: garth status [--json]"
    return 0
  elif [[ $# -gt 0 ]]; then
    garth_die "Unknown option for status: $1" 1
  fi

  ensure_state_root

  local -a sessions=()
  local dir
  for dir in "$GARTH_STATE_ROOT"/sessions/*; do
    [[ -d "$dir" ]] || continue
    [[ -f "$dir/active" ]] || continue
    sessions+=("$(basename "$dir")")
  done

  if [[ "$as_json" == "true" ]]; then
    if [[ ${#sessions[@]} -eq 0 ]]; then
      echo '{"sessions":[]}'
      return 0
    fi

    local first=true
    printf '{"sessions":['
    local session
    for session in "${sessions[@]}"; do
      local session_dir="$GARTH_STATE_ROOT/sessions/$session"
      local repo_root branch agents_csv token_state started_epoch
      repo_root=$(read_state_value "$session_dir" "repo_root")
      branch=$(read_state_value "$session_dir" "branch")
      agents_csv=$(read_state_value "$session_dir" "agents_csv")
      token_state=$(read_state_value "$session_dir" "token_state")
      started_epoch=$(read_state_value "$session_dir" "started_epoch")
      local now uptime
      now=$(garth_now_epoch)
      uptime=$((now - ${started_epoch:-$now}))
      local containers
      containers=$(count_session_containers "$session")

      [[ "$first" == "true" ]] || printf ','
      first=false
      garth_python - << 'PY' "$session" "$repo_root" "$branch" "$agents_csv" "$token_state" "$uptime" "$containers"
import json
import sys
session, repo_root, branch, agents_csv, token_state, uptime, containers = sys.argv[1:]
obj = {
    "session": session,
    "repo": repo_root,
    "branch": branch,
    "agents": [a for a in agents_csv.split(',') if a],
    "containers": int(containers),
    "token_state": token_state or "unknown",
    "uptime_seconds": int(uptime),
}
print(json.dumps(obj), end="")
PY
    done
    echo ']}'
    return 0
  fi

  if [[ ${#sessions[@]} -eq 0 ]]; then
    echo "No active garth sessions."
    return 0
  fi

  printf '%-32s %-20s %-18s %-18s %-10s %-12s %-8s\n' \
    "SESSION" "REPO" "BRANCH" "AGENTS" "CONTAINERS" "TOKEN" "UPTIME"

  local session
  for session in "${sessions[@]}"; do
    local session_dir="$GARTH_STATE_ROOT/sessions/$session"
    local repo_root branch agents_csv token_state started_epoch
    repo_root=$(read_state_value "$session_dir" "repo_root")
    branch=$(read_state_value "$session_dir" "branch")
    agents_csv=$(read_state_value "$session_dir" "agents_csv")
    token_state=$(read_state_value "$session_dir" "token_state")
    started_epoch=$(read_state_value "$session_dir" "started_epoch")

    local repo_short
    repo_short=$(basename "$repo_root")
    local now uptime containers
    now=$(garth_now_epoch)
    uptime=$(human_uptime $((now - ${started_epoch:-$now})))
    containers=$(count_session_containers "$session")

    printf '%-32s %-20s %-18s %-18s %-10s %-12s %-8s\n' \
      "$session" "$repo_short" "$branch" "$agents_csv" "$containers" "${token_state:-unknown}" "$uptime"
  done
}

stop_session() {
  local session="$1"
  local session_dir
  session_dir=$(session_dir_for "$session")
  [[ -d "$session_dir" ]] || return 0

  local repo_root worktree branch agents_csv
  repo_root=$(read_state_value "$session_dir" "repo_root")
  worktree=$(read_state_value "$session_dir" "worktree")
  branch=$(read_state_value "$session_dir" "branch")
  agents_csv=$(read_state_value "$session_dir" "agents_csv")
  garth_audit_log "$session_dir" "session_stop_requested" \
    "session=$session" \
    "repo_root=$repo_root" \
    "worktree=$worktree" \
    "branch=$branch" \
    "agents=$agents_csv"

  rm -f "$session_dir/active" 2>/dev/null || true

  local pid
  pid=$(read_state_value "$session_dir" "refresher_pid")
  if [[ -n "$pid" ]]; then
    kill "$pid" >/dev/null 2>&1 || true
    garth_audit_log "$session_dir" "token_refresher_stopped" \
      "session=$session" \
      "refresher_pid=$pid"
  fi

  if command -v docker >/dev/null 2>&1; then
    garth_stop_containers_for_session "$session"
    garth_audit_log "$session_dir" "container_stop" \
      "session=$session"
  fi

  garth_zellij_kill_session "$session"
  garth_audit_log "$session_dir" "zellij_stop" \
    "session=$session"
  garth_post_session_report "$session" "$session_dir" "$worktree"

  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    echo "[dry-run] rm -rf $session_dir"
  else
    garth_audit_log "$session_dir" "session_stop_complete" \
      "session=$session"
    rm -rf "$session_dir"
  fi
}

cmd_stop() {
  local target_session=""
  local repo_dir=""
  local stop_all=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        repo_dir="$2"
        shift 2
        ;;
      --all)
        stop_all=true
        shift
        ;;
      --yes|-y)
        GARTH_YES=true
        shift
        ;;
      --dry-run)
        GARTH_DRY_RUN=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth stop <session>|--repo <dir>|--all [--yes]
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for stop: $1" 1
        ;;
      *)
        if [[ -z "$target_session" ]]; then
          target_session="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done

  local modes=0
  [[ -n "$target_session" ]] && modes=$((modes + 1))
  [[ -n "$repo_dir" ]] && modes=$((modes + 1))
  [[ "$stop_all" == "true" ]] && modes=$((modes + 1))
  [[ "$modes" -eq 1 ]] || garth_die "Choose exactly one target: <session> or --repo or --all" 1

  ensure_state_root

  local -a targets=()
  if [[ "$stop_all" == "true" ]]; then
    if ! garth_ask_yn "Stop all garth sessions?"; then
      garth_log_info "Aborted"
      return 0
    fi
    local d
    for d in "$GARTH_STATE_ROOT"/sessions/*; do
      [[ -d "$d" ]] || continue
      targets+=("$(basename "$d")")
    done
  elif [[ -n "$repo_dir" ]]; then
    local repo_root
    repo_root=$(garth_git_repo_root "$repo_dir") || garth_die "Not inside a git repo: $repo_dir" 1
    local d
    for d in "$GARTH_STATE_ROOT"/sessions/*; do
      [[ -d "$d" ]] || continue
      local sr
      sr=$(read_state_value "$d" "repo_root")
      if [[ "$sr" == "$repo_root" ]]; then
        targets+=("$(basename "$d")")
      fi
    done
  else
    targets+=("$target_session")
  fi

  if [[ ${#targets[@]} -eq 0 ]]; then
    garth_die "No matching sessions found" 5
  fi

  local session
  for session in "${targets[@]}"; do
    garth_log_info "Stopping session: $session"
    stop_session "$session"
  done
}

garth_sed_escape_replacement() {
  printf '%s' "$1" | sed -e 's/[&|\\]/\\&/g'
}

garth_set_config_string_value() {
  local key="$1"
  local value="$2"
  local escaped
  escaped=$(garth_sed_escape_replacement "$value")
  sed -i.bak "s|^${key} = \".*\"|${key} = \"${escaped}\"|" "$GARTH_CONFIG_PATH"
  rm -f "$GARTH_CONFIG_PATH.bak"
}

garth_prompt_with_default() {
  local prompt="$1"
  local default="$2"
  local answer=""
  read -r -p "$prompt [$default]: " answer
  if [[ -z "$answer" ]]; then
    answer="$default"
  fi
  printf '%s' "$answer"
}

garth_first_vault_name() {
  op vault list --format json 2>/dev/null | garth_python - << 'PY'
import json
import sys
try:
    data = json.load(sys.stdin)
except Exception:
    raise SystemExit(1)
if isinstance(data, list) and data:
    first = data[0]
    if isinstance(first, dict):
        print(first.get("name", ""))
PY
}

garth_list_vault_names() {
  op vault list --format json 2>/dev/null | garth_python - << 'PY'
import json
import sys
try:
    data = json.load(sys.stdin)
except Exception:
    raise SystemExit(0)
if not isinstance(data, list):
    raise SystemExit(0)
for item in data:
    if isinstance(item, dict):
        name = item.get("name")
        if isinstance(name, str) and name:
            print(f"  - {name}")
PY
}

garth_validate_ref_readable() {
  local ref="$1"
  op read "$ref" >/dev/null 2>&1
}

garth_ref_looks_configured() {
  local ref="$1"
  [[ -n "$ref" ]] || return 1
  [[ "$ref" == op://* ]] || return 1
  [[ "$ref" != *"<"* ]]
}

garth_github_app_refs_look_configured() {
  garth_ref_looks_configured "${GARTH_GITHUB_APP_APP_ID_REF:-}" || return 1
  garth_ref_looks_configured "${GARTH_GITHUB_APP_PRIVATE_KEY_REF:-}" || return 1

  case "${GARTH_GITHUB_APP_INSTALLATION_STRATEGY:-by_owner}" in
    single)
      garth_ref_looks_configured "${GARTH_GITHUB_APP_INSTALLATION_ID_REF:-}" || return 1
      ;;
    static_map|by_owner)
      :
      ;;
    *)
      return 1
      ;;
  esac

  return 0
}

garth_prompt_op_signin() {
  if [[ "$GARTH_YES" == "true" ]]; then
    garth_log_info "1Password CLI is not signed in; attempting automatic 'op signin'"
    if ! eval "$(op signin)"; then
      garth_log_warn "Automatic op signin failed; skipping GitHub App ref setup"
      garth_log_info "Run: eval \"\$(op signin)\" and then rerun 'garth setup'"
      return 1
    fi

    if ! op whoami >/dev/null 2>&1; then
      garth_log_warn "Automatic op signin did not establish a CLI session; skipping GitHub App ref setup"
      return 1
    fi

    garth_log_success "1Password CLI sign-in complete"
    return 0
  fi

  garth_log_warn "1Password CLI is not signed in"
  if ! garth_ask_yn "Run 'op signin' now?"; then
    garth_log_warn "Skipping GitHub App ref setup: op CLI is not signed in"
    garth_log_info "Run: eval \"\$(op signin)\" and then rerun 'garth setup'"
    return 1
  fi

  if ! eval "$(op signin)"; then
    garth_log_warn "op signin failed; skipping GitHub App ref setup"
    garth_log_info "Run: eval \"\$(op signin)\" and then rerun 'garth setup'"
    return 1
  fi

  if ! op whoami >/dev/null 2>&1; then
    garth_log_warn "op signin did not establish a CLI session; skipping GitHub App ref setup"
    return 1
  fi

  garth_log_success "1Password CLI sign-in complete"
  return 0
}

garth_configure_github_app_refs() {
  # Skip guided ref setup when config already contains non-placeholder op:// refs.
  load_config
  if garth_github_app_refs_look_configured; then
    garth_log_info "GitHub App refs already configured in $GARTH_CONFIG_PATH; skipping guided setup"
    return 0
  fi

  if ! command -v op >/dev/null 2>&1; then
    garth_log_warn "Skipping GitHub App ref setup: op CLI not installed"
    return 0
  fi

  if ! op whoami >/dev/null 2>&1; then
    garth_prompt_op_signin || return 0
  fi

  if [[ "$GARTH_YES" == "true" ]]; then
    garth_log_info "Non-interactive setup: skipped guided GitHub App ref prompts"
    garth_log_info "Edit $GARTH_CONFIG_PATH [github_app] refs to match your 1Password vault/item"
    return 0
  fi

  if ! garth_ask_yn "Configure GitHub App 1Password refs now?"; then
    return 0
  fi

  garth_log_info "Available vaults:"
  garth_list_vault_names || true

  local default_vault
  default_vault=$(garth_first_vault_name || true)
  [[ -n "$default_vault" ]] || default_vault="Private"

  local vault item app_field private_key_field installation_field
  vault=$(garth_prompt_with_default "Vault name" "$default_vault")
  item=$(garth_prompt_with_default "Item name" "GitHub App")
  app_field=$(garth_prompt_with_default "App ID field label or id" "app-id")
  private_key_field=$(garth_prompt_with_default "Private key field label or id" "private-key")
  installation_field=$(garth_prompt_with_default "Installation ID field label or id" "installation-id")

  local app_ref private_ref installation_ref
  app_ref="op://${vault}/${item}/${app_field}"
  private_ref="op://${vault}/${item}/${private_key_field}"
  installation_ref="op://${vault}/${item}/${installation_field}"

  garth_set_config_string_value "app_id_ref" "$app_ref"
  garth_set_config_string_value "private_key_ref" "$private_ref"
  garth_set_config_string_value "installation_id_ref" "$installation_ref"

  local ok=true
  if ! garth_validate_ref_readable "$app_ref"; then
    garth_log_warn "Cannot read app_id_ref: $app_ref"
    ok=false
  fi
  if ! garth_validate_ref_readable "$private_ref"; then
    garth_log_warn "Cannot read private_key_ref: $private_ref"
    ok=false
  fi
  if ! garth_validate_ref_readable "$installation_ref"; then
    garth_log_warn "Cannot read installation_id_ref: $installation_ref"
    ok=false
  fi

  if [[ "$ok" == "true" ]]; then
    garth_log_success "Updated and validated [github_app] refs"
  else
    garth_log_warn "Saved refs but validation failed. Check vault/item/field names in $GARTH_CONFIG_PATH"
  fi
}

garth_setup_aerospace() {
  local non_interactive="$1"

  if ! garth_is_macos; then
    return 0
  fi

  if command -v aerospace >/dev/null 2>&1; then
    garth_log_success "aerospace is installed"
    return 0
  fi

  garth_log_warn "aerospace is not installed; workspace auto-placement needs it"
  if ! command -v brew >/dev/null 2>&1; then
    garth_log_warn "Homebrew not found. Install AeroSpace manually from https://github.com/nikitabobko/AeroSpace"
    return 0
  fi

  if [[ "$non_interactive" == "true" ]] || garth_ask_yn "Install AeroSpace via Homebrew now?"; then
    garth_log_info "Installing AeroSpace via Homebrew"
    if brew tap nikitabobko/tap && brew install --cask aerospace; then
      garth_log_success "Installed aerospace"
    else
      garth_log_warn "AeroSpace install failed. Run manually:"
      garth_log_warn "  brew tap nikitabobko/tap && brew install --cask aerospace"
    fi
  else
    garth_log_warn "Skipping AeroSpace install. Workspace auto-placement will be disabled."
  fi
}

garth_setup_python3() {
  local non_interactive="${1:-false}"

  if ! garth_is_macos; then
    return 0
  fi

  local py_path py_ver
  py_path="$(command -v "$GARTH_PYTHON_BIN" || true)"
  py_ver="$("$GARTH_PYTHON_BIN" --version 2>/dev/null || true)"

  if [[ "$py_path" != "/usr/bin/python3" ]]; then
    return 0
  fi

  garth_log_warn "Detected macOS system python3 ($py_ver at $py_path)"
  garth_log_warn "This can trigger Command Line Tools prompts during setup/use."

  if [[ -x "/opt/homebrew/bin/python3" ]]; then
    garth_log_info "Homebrew python3 already installed at /opt/homebrew/bin/python3"
    garth_log_warn "Ensure /opt/homebrew/bin appears before /usr/bin in your PATH."
    return 0
  fi

  if ! command -v brew >/dev/null 2>&1; then
    garth_log_warn "Homebrew not found. Install Homebrew, then run: brew install python"
    return 0
  fi

  if [[ "$non_interactive" == "true" ]] || garth_ask_yn "Install Homebrew python now?"; then
    garth_log_info "Installing Homebrew python"
    if brew install python; then
      garth_log_success "Installed Homebrew python"
      garth_log_warn "Add to shell init if needed:"
      garth_log_warn "  export PATH=\"/opt/homebrew/bin:\$PATH\""
    else
      garth_log_warn "Homebrew python install failed. Run manually: brew install python"
    fi
  else
    garth_log_warn "Skipping Homebrew python install."
  fi
}

cmd_setup() {
  local non_interactive=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y)
        GARTH_YES=true
        non_interactive=true
        shift
        ;;
      --help|-h)
        echo "Usage: garth setup [--yes]"
        return 0
        ;;
      *)
        garth_die "Unknown option for setup: $1" 1
        ;;
    esac
  done

  garth_log_info "Checking prerequisites"
  garth_require_cmd git
  if [[ "$GARTH_PYTHON_BIN" == */* ]]; then
    [[ -x "$GARTH_PYTHON_BIN" ]] || garth_die "Missing required command: $GARTH_PYTHON_BIN" 2
  else
    garth_require_cmd "$GARTH_PYTHON_BIN"
  fi
  garth_setup_python3 "$non_interactive"

  local optional=(docker zellij op)
  local cmd
  for cmd in "${optional[@]}"; do
    if command -v "$cmd" >/dev/null 2>&1; then
      garth_log_success "$cmd is installed"
    else
      garth_log_warn "$cmd is not installed"
    fi
  done

  garth_setup_aerospace "$non_interactive"

  local config_dir
  config_dir=$(dirname "$GARTH_CONFIG_PATH")
  mkdir -p "$config_dir"

  if [[ ! -f "$GARTH_CONFIG_PATH" ]]; then
    local template_path="$GARTH_ROOT/config.example.toml"
    [[ -f "$template_path" ]] || \
      garth_die "Config template not found: $template_path" 1
    cp "$template_path" "$GARTH_CONFIG_PATH"
    garth_log_success "Created config: $GARTH_CONFIG_PATH"

    if garth_ask_yn "Use permissive safety mode by default?"; then
      sed -i.bak 's/^safety_mode = "safe"/safety_mode = "permissive"/' "$GARTH_CONFIG_PATH"
      rm -f "$GARTH_CONFIG_PATH.bak"
      garth_log_warn "Set defaults.safety_mode=permissive"
    fi
  else
    garth_log_info "Config already exists: $GARTH_CONFIG_PATH"
  fi

  garth_configure_github_app_refs

  if garth_python "$GARTH_ROOT/lib/config-parser.py" validate "$GARTH_CONFIG_PATH"; then
    garth_log_success "Config validation passed"
  else
    garth_die "Config validation failed" 1
  fi

  local local_bin="$HOME/.local/bin"
  mkdir -p "$local_bin"
  ln -sf "$GARTH_BIN_PATH" "$local_bin/garth"
  garth_log_success "Installed symlink: $local_bin/garth"

  if [[ -f "$GARTH_ROOT/docker/Dockerfile" ]]; then
    if ! command -v docker >/dev/null 2>&1; then
      garth_log_warn "Skipping Docker image build: docker is not installed"
    else
      load_config
      local image_prefix="$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX"
      local -a missing_agents=()
      local agent image_tag state docker_issue=""
      for agent in claude codex; do
        image_tag="${image_prefix}-${agent}:latest"
        state=$(garth_docker_image_state "$image_tag")
        case "$state" in
          present) ;;
          missing) missing_agents+=("$agent") ;;
          unavailable:*)
            docker_issue="${state#unavailable:}"
            break
            ;;
        esac
      done

      if [[ -n "$docker_issue" ]]; then
        garth_log_warn "Could not query Docker image state: $docker_issue"
        garth_log_warn "Skipping automatic Docker image build. Check Docker daemon/context."
      elif [[ ${#missing_agents[@]} -eq 0 ]]; then
        garth_log_info "Default Docker images exist; validating agent CLIs"
        for agent in claude codex; do
          if garth_ensure_agent_image_ready "$agent" "$image_prefix"; then
            garth_log_success "Docker image ready: ${image_prefix}-${agent}:latest"
          else
            garth_log_warn "Docker image validation failed: ${image_prefix}-${agent}:latest"
          fi
        done
      else
        local missing_csv
        missing_csv=$(IFS=','; echo "${missing_agents[*]}")
        garth_log_info "Building missing default Docker image(s): ${missing_csv}"
        for agent in "${missing_agents[@]}"; do
          if garth_ensure_agent_image_ready "$agent" "$image_prefix"; then
            garth_log_success "Docker image ready: ${image_prefix}-${agent}:latest"
          else
            garth_log_warn "Docker image build/validation failed: ${image_prefix}-${agent}:latest"
          fi
        done
      fi
    fi
  fi

  garth_log_info "Credential checklist:"
  garth_log_info "  1) Ensure [github_app] refs in $GARTH_CONFIG_PATH point to real vault/item fields"
  garth_log_info "  2) Set API key refs under [agents.*] (Anthropic/OpenAI/Google as needed)"
  garth_log_info "  3) Test with: garth token ."

  garth_log_success "Setup complete"
}

cmd_internal_refresh() {
  local repo_root=""
  local session=""
  local session_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-root)
        repo_root="$2"
        shift 2
        ;;
      --session)
        session="$2"
        shift 2
        ;;
      --session-dir)
        session_dir="$2"
        shift 2
        ;;
      *)
        garth_die "Unknown option for internal-refresh: $1" 1
        ;;
    esac
  done

  [[ -n "$repo_root" && -n "$session" && -n "$session_dir" ]] || garth_die "internal-refresh requires --repo-root --session --session-dir" 1

  load_config

  local lead_seconds retry_window_seconds initial_interval_seconds max_interval_seconds
  lead_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_LEAD_TIME")
  retry_window_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_FAILURE_RETRY_WINDOW")
  initial_interval_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_RETRY_INITIAL_INTERVAL")
  max_interval_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_RETRY_MAX_INTERVAL")
  garth_audit_log "$session_dir" "token_refresher_loop_started" \
    "session=$session" \
    "repo_root=$repo_root"

  while [[ -f "$session_dir/active" ]]; do
    local now expires_epoch wait_seconds
    now=$(garth_now_epoch)
    expires_epoch=$(read_state_value "$session_dir" "token_expires_epoch")
    if [[ -z "$expires_epoch" ]]; then
      sleep_with_session_guard 5 "$session_dir" || break
      continue
    fi

    wait_seconds=$((expires_epoch - now - lead_seconds))
    if ((wait_seconds > 0)); then
      sleep_with_session_guard "$wait_seconds" "$session_dir" || break
    fi

    local success=false
    local attempt_started backoff
    attempt_started=$(garth_now_epoch)
    backoff="$initial_interval_seconds"

    while [[ -f "$session_dir/active" ]]; do
      local token_line
      local token_cmd_rc=0
      if token_line=$("$GARTH_BIN_PATH" token "$repo_root" --machine 2>/dev/null); then
        local token expires_at refreshed_epoch installation_id owner_repo
        IFS=$'\t' read -r token expires_at refreshed_epoch installation_id owner_repo <<< "$token_line"
        garth_write_token_file "$session_dir" "$token" >/dev/null
        write_state_value "$session_dir" "token_expires_at" "$expires_at"
        write_state_value "$session_dir" "token_expires_epoch" "$refreshed_epoch"
        write_state_value "$session_dir" "token_state" "ok"
        garth_audit_log "$session_dir" "token_refresh_success" \
          "session=$session" \
          "owner_repo=$owner_repo" \
          "installation_id=$installation_id" \
          "token=$token" \
          "token_expires_at=$expires_at"
        success=true
        break
      fi
      token_cmd_rc=$?
      garth_audit_log "$session_dir" "token_refresh_failure" \
        "session=$session" \
        "repo_root=$repo_root" \
        "exit_code=$token_cmd_rc"

      local elapsed
      elapsed=$(( $(garth_now_epoch) - attempt_started ))

      if ((retry_window_seconds == 0)); then
        write_state_value "$session_dir" "token_state" "degraded"
        garth_audit_log "$session_dir" "token_refresh_degraded" \
          "session=$session" \
          "state=degraded" \
          "reason=retry_window_disabled"
        break
      fi

      if ((retry_window_seconds != -1 && elapsed >= retry_window_seconds)); then
        write_state_value "$session_dir" "token_state" "degraded"
        garth_audit_log "$session_dir" "token_refresh_degraded" \
          "session=$session" \
          "state=degraded" \
          "reason=retry_window_exceeded"
        break
      fi

      sleep_with_session_guard "$backoff" "$session_dir" || break

      if [[ "$GARTH_TOKEN_REFRESH_RETRY_BACKOFF" == "exponential" ]]; then
        backoff=$((backoff * 2))
        if ((backoff > max_interval_seconds)); then
          backoff="$max_interval_seconds"
        fi
      fi
    done

    if [[ "$success" != "true" ]]; then
      sleep_with_session_guard "$max_interval_seconds" "$session_dir" || break
    fi
  done
  garth_audit_log "$session_dir" "token_refresher_loop_stopped" \
    "session=$session"
}

doctor_try_op_signin() {
  if op whoami >/dev/null 2>&1; then
    return 0
  fi
  if [[ ! -t 0 || ! -t 1 ]]; then
    return 1
  fi
  garth_log_info "1Password CLI session missing; attempting 'eval \"\$(op signin)\"'"
  eval "$(op signin)" >/dev/null 2>&1 || return 1
  op whoami >/dev/null 2>&1
}

cmd_doctor() {
  local repo_dir="."
  local skip_token=false
  local deep_checks=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        repo_dir="$2"
        shift 2
        ;;
      --skip-token)
        skip_token=true
        shift
        ;;
      --deep)
        deep_checks=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth doctor [--repo <dir>] [--skip-token] [--deep]

Checks:
  - required commands and optional tooling
  - config presence and schema validation
  - GitHub App ref shape + readability
  - GitHub private key PEM validity
  - optional token mint test for a target repo (default: .)
  - default Docker image presence (claude/codex)
  - optional feature checks (for example Neovim install/mount)
  - with --deep: runtime Docker auth/startup probes for passthrough agents
HELP
        return 0
        ;;
      *)
        garth_die "Unknown option for doctor: $1" 1
        ;;
    esac
  done

  local failures=0
  local warnings=0
  local config_ok=false
  local config_loaded=false
  local op_available=false
  local op_session=false

  garth_log_info "Doctor checks starting"

  local required_cmd
  for required_cmd in git python3; do
    if command -v "$required_cmd" >/dev/null 2>&1; then
      garth_log_success "Required command found: $required_cmd"
    else
      garth_log_error "Missing required command: $required_cmd"
      failures=$((failures + 1))
    fi
  done

  local optional_cmd
  local optional_cmds=(op docker zellij)
  if garth_is_macos; then
    optional_cmds+=(aerospace)
  fi
  for optional_cmd in "${optional_cmds[@]}"; do
    if command -v "$optional_cmd" >/dev/null 2>&1; then
      garth_log_success "Optional command found: $optional_cmd"
      [[ "$optional_cmd" == "op" ]] && op_available=true
    else
      garth_log_warn "Optional command missing: $optional_cmd"
      warnings=$((warnings + 1))
    fi
  done

  if [[ -f "$GARTH_CONFIG_PATH" ]]; then
    garth_log_success "Config exists: $GARTH_CONFIG_PATH"
    config_ok=true
  else
    garth_log_error "Config missing: $GARTH_CONFIG_PATH"
    failures=$((failures + 1))
  fi

  if [[ "$config_ok" == "true" ]]; then
    if garth_python "$GARTH_ROOT/lib/config-parser.py" validate "$GARTH_CONFIG_PATH" >/dev/null; then
      garth_log_success "Config validation passed"
    else
      garth_log_error "Config validation failed"
      failures=$((failures + 1))
    fi

    local env_export
    if env_export=$(config_env 2>/dev/null); then
      eval "$env_export"
      config_loaded=true
      garth_log_success "Config load passed"
    else
      garth_log_error "Config load failed"
      failures=$((failures + 1))
    fi
  fi

  if [[ "$config_loaded" == "true" ]]; then
    if garth_github_app_refs_look_configured; then
      garth_log_success "GitHub App refs look configured"
    else
      garth_log_warn "GitHub App refs look incomplete/placeholders"
      warnings=$((warnings + 1))
    fi

    local defaults_sandbox
    defaults_sandbox="$GARTH_DEFAULTS_SANDBOX"
    csv_to_array "$GARTH_DEFAULTS_AGENTS_CSV"
    local doctor_agent doctor_api_ref
    for doctor_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
      doctor_api_ref=$(garth_agent_field "$doctor_agent" "API_KEY_REF")
      if garth_ref_looks_configured "$doctor_api_ref"; then
        garth_log_success "agents.$doctor_agent.api_key_ref looks configured"
      else
        if [[ "$defaults_sandbox" == "none" ]] || csv_contains_token "$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV" "$doctor_agent"; then
          garth_log_warn "agents.$doctor_agent.api_key_ref is missing or a placeholder: ${doctor_api_ref:-<empty>}"
          garth_log_warn "  Allowed by current defaults because local CLI auth mode is enabled."
          warnings=$((warnings + 1))
        else
          garth_log_error "agents.$doctor_agent.api_key_ref is missing or a placeholder: ${doctor_api_ref:-<empty>}"
          garth_log_error "  Required for defaults.sandbox=docker unless defaults.auth_passthrough includes '$doctor_agent'."
          failures=$((failures + 1))
        fi
      fi
    done
  fi

  if [[ "$op_available" == "true" ]]; then
    if [[ "$config_loaded" == "true" ]] && garth_ref_looks_configured "$GARTH_GITHUB_APP_APP_ID_REF"; then
      if op read "$GARTH_GITHUB_APP_APP_ID_REF" >/dev/null 2>&1; then
        op_session=true
        garth_log_success "1Password CLI session available"
      elif doctor_try_op_signin && op read "$GARTH_GITHUB_APP_APP_ID_REF" >/dev/null 2>&1; then
        op_session=true
        garth_log_success "1Password CLI session available"
      else
        garth_log_warn "1Password CLI is not signed in or cannot read configured refs"
        warnings=$((warnings + 1))
      fi
    else
      if op whoami >/dev/null 2>&1 || doctor_try_op_signin; then
        op_session=true
        garth_log_success "1Password CLI session available"
      else
        garth_log_warn "1Password CLI is not signed in"
        warnings=$((warnings + 1))
      fi
    fi
  fi

  if [[ "$config_loaded" == "true" && "$op_session" == "true" ]]; then
    local app_ref key_ref install_ref
    app_ref="$GARTH_GITHUB_APP_APP_ID_REF"
    key_ref="$GARTH_GITHUB_APP_PRIVATE_KEY_REF"
    install_ref="$GARTH_GITHUB_APP_INSTALLATION_ID_REF"

    if garth_validate_ref_readable "$app_ref"; then
      garth_log_success "Readable app_id_ref"
    else
      garth_log_error "Unreadable app_id_ref: $app_ref"
      failures=$((failures + 1))
    fi

    if garth_validate_ref_readable "$key_ref"; then
      garth_log_success "Readable private_key_ref"
      local tmp_key
      tmp_key=$(mktemp "${TMPDIR:-/tmp}/garth-doctor-key.XXXXXX")
      garth_register_cleanup_path "$tmp_key"
      op read "$key_ref" > "$tmp_key" 2>/dev/null || true
      if ! garth_github_private_key_valid "$tmp_key"; then
        garth_github_normalize_private_key_file "$tmp_key"
      fi
      if garth_github_private_key_valid "$tmp_key"; then
        garth_log_success "GitHub private key PEM is valid"
      else
        garth_log_error "GitHub private key PEM is invalid for ref: $key_ref"
        failures=$((failures + 1))
      fi
    else
      garth_log_error "Unreadable private_key_ref: $key_ref"
      failures=$((failures + 1))
    fi

    if [[ "$GARTH_GITHUB_APP_INSTALLATION_STRATEGY" == "single" ]]; then
      if garth_validate_ref_readable "$install_ref"; then
        garth_log_success "Readable installation_id_ref (single strategy)"
      else
        garth_log_error "Unreadable installation_id_ref: $install_ref"
        failures=$((failures + 1))
      fi
    fi

    csv_to_array "$GARTH_DEFAULTS_AGENTS_CSV"
    local doctor_agent doctor_api_ref
    for doctor_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
      doctor_api_ref=$(garth_agent_field "$doctor_agent" "API_KEY_REF")
      if garth_ref_looks_configured "$doctor_api_ref"; then
        if garth_validate_ref_readable "$doctor_api_ref"; then
          garth_log_success "Readable agents.$doctor_agent.api_key_ref"
        else
          garth_log_error "Unreadable agents.$doctor_agent.api_key_ref: $doctor_api_ref"
          failures=$((failures + 1))
        fi
      else
        garth_log_info "Skipping agents.$doctor_agent.api_key_ref readability check (placeholder/missing)"
      fi
    done
  fi

  if [[ "$config_loaded" == "true" && -d "$repo_dir" ]]; then
    local repo_root remote_url owner_repo
    if repo_root=$(garth_git_repo_root "$repo_dir" 2>/dev/null); then
      if remote_url=$(garth_git_remote_url "$repo_root" "origin" 2>/dev/null) && \
         owner_repo=$(garth_git_owner_repo_from_remote "$remote_url" 2>/dev/null); then
        garth_log_success "Repo remote parsed: $owner_repo"
        if [[ "$skip_token" == "false" ]]; then
          if [[ "$op_session" == "true" ]]; then
            local token_line
            if token_line=$("$GARTH_BIN_PATH" token "$repo_root" --machine 2>/dev/null); then
              garth_log_success "Token mint test passed"
            else
              garth_log_error "Token mint test failed for repo: $repo_root"
              failures=$((failures + 1))
            fi
          else
            garth_log_warn "Skipping token mint test: 1Password CLI session unavailable"
            warnings=$((warnings + 1))
          fi
        fi
      else
        garth_log_warn "Repo origin is not a supported GitHub URL: $repo_root"
        warnings=$((warnings + 1))
      fi
    else
      garth_log_warn "Not a git repo (token test skipped): $repo_dir"
      warnings=$((warnings + 1))
    fi
  fi

  if [[ "$config_loaded" == "true" ]]; then
    if [[ "${GARTH_FEATURES_MOUNT_NEOVIM_CONFIG:-false}" == "true" ]]; then
      if [[ -d "$HOME/.config/nvim" ]]; then
        garth_log_success "Neovim config mount source exists: $HOME/.config/nvim"
      else
        garth_log_warn "features.mount_neovim_config=true but path is missing: $HOME/.config/nvim"
        warnings=$((warnings + 1))
      fi
    fi
  fi

  if [[ "$config_loaded" == "true" ]] && command -v docker >/dev/null 2>&1; then
    local image_prefix image_tag agent state
    image_prefix="$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX"
    for agent in claude codex; do
      image_tag="${image_prefix}-${agent}:latest"
      state=$(garth_docker_image_state "$image_tag")
      case "$state" in
        present)
          garth_log_success "Docker image present: $image_tag"
          if [[ "${GARTH_FEATURES_INSTALL_NEOVIM:-false}" == "true" ]]; then
            if garth_docker_image_has_binary "$image_tag" "nvim"; then
              garth_log_success "Docker image has Neovim: $image_tag"
            else
              garth_log_warn "features.install_neovim=true but image lacks nvim: $image_tag"
              warnings=$((warnings + 1))
            fi
          fi
          if [[ "${GARTH_FEATURES_INSTALL_UV:-false}" == "true" ]]; then
            if garth_docker_image_has_binary "$image_tag" "uv"; then
              garth_log_success "Docker image has uv: $image_tag"
            else
              garth_log_warn "features.install_uv=true but image lacks uv: $image_tag"
              warnings=$((warnings + 1))
            fi
          fi
          ;;
        missing)
          garth_log_warn "Docker image missing: $image_tag"
          warnings=$((warnings + 1))
          ;;
        unavailable:*)
          garth_log_warn "Could not inspect Docker image $image_tag: ${state#unavailable:}"
          garth_log_warn "Check Docker daemon/context; image presence could not be verified."
          warnings=$((warnings + 1))
          ;;
      esac
    done
  fi

  if [[ "$deep_checks" == "true" ]]; then
    if [[ "$config_loaded" != "true" ]]; then
      garth_log_warn "Skipping deep checks: config did not load"
      warnings=$((warnings + 1))
    elif ! command -v docker >/dev/null 2>&1; then
      garth_log_warn "Skipping deep checks: docker command is unavailable"
      warnings=$((warnings + 1))
    else
      local deep_image_prefix
      deep_image_prefix="$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX"

      if csv_contains_token "$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV" "claude"; then
        local claude_image
        claude_image="${deep_image_prefix}-claude:latest"
        local claude_state
        claude_state=$(garth_docker_image_state "$claude_image")
        if [[ "$claude_state" != "present" ]]; then
          garth_log_warn "Skipping Claude deep checks: Docker image unavailable: $claude_image ($claude_state)"
          warnings=$((warnings + 1))
        else
          garth_log_info "Deep check: probing Claude Docker auth/startup path"
          local -a claude_mount_args=()
          local mount_arg
          while IFS= read -r mount_arg; do
            claude_mount_args+=("$mount_arg")
          done < <(garth_container_emit_auth_mounts_lines "claude" || true)

          if [[ ${#claude_mount_args[@]} -eq 0 ]]; then
            garth_log_warn "Skipping Claude deep checks: no passthrough mount paths found"
            warnings=$((warnings + 1))
          else
            local preamble preamble_escaped auth_status_json state_probe_json
            preamble=$(garth_claude_runtime_preamble)
            printf -v preamble_escaped '%q' "$preamble"

            if auth_status_json=$(docker run --rm \
              --read-only \
              --tmpfs /tmp:rw,noexec,nosuid,size=256m \
              --tmpfs /home/agent:rw,exec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.cache:rw,noexec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.local:rw,exec,nosuid,size=256m,uid=1001,gid=1001,mode=0700 \
              "${claude_mount_args[@]}" \
              --env HOME=/home/agent \
              --env XDG_CACHE_HOME=/home/agent/.cache \
              --env XDG_CONFIG_HOME=/home/agent/.config \
              --env XDG_STATE_HOME=/home/agent/.local/state \
              --env PATH=/home/agent/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
              "$claude_image" \
              bash -lc "eval ${preamble_escaped}; claude auth status" 2>/dev/null); then
              if printf '%s\n' "$auth_status_json" | grep -Eq '"loggedIn"[[:space:]]*:[[:space:]]*true'; then
                garth_log_success "Deep check passed: Claude auth status is logged in in container"
              else
                garth_log_error "Deep check failed: Claude auth status did not report logged in"
                failures=$((failures + 1))
              fi
            else
              garth_log_error "Deep check failed: unable to execute 'claude auth status' in container"
              failures=$((failures + 1))
            fi

            if state_probe_json=$(docker run --rm \
              --read-only \
              --tmpfs /tmp:rw,noexec,nosuid,size=256m \
              --tmpfs /home/agent:rw,exec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.cache:rw,noexec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.local:rw,exec,nosuid,size=256m,uid=1001,gid=1001,mode=0700 \
              "${claude_mount_args[@]}" \
              --env HOME=/home/agent \
              --env XDG_CACHE_HOME=/home/agent/.cache \
              --env XDG_CONFIG_HOME=/home/agent/.config \
              --env XDG_STATE_HOME=/home/agent/.local/state \
              --env PATH=/home/agent/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
              "$claude_image" \
              bash -lc "eval ${preamble_escaped}; jq -c '{has_oauth: (.oauthAccount | type == \"object\"), has_first_start: has(\"firstStartTime\")}' /home/agent/.claude.json" 2>/dev/null); then
              if printf '%s\n' "$state_probe_json" | grep -Eq '"has_oauth":[[:space:]]*true' && \
                 printf '%s\n' "$state_probe_json" | grep -Eq '"has_first_start":[[:space:]]*true'; then
                garth_log_success "Deep check passed: Claude state file has oauth + firstStartTime"
              else
                garth_log_error "Deep check failed: Claude state file is missing oauth or firstStartTime"
                failures=$((failures + 1))
              fi
            else
              garth_log_error "Deep check failed: unable to inspect /home/agent/.claude.json in container"
              failures=$((failures + 1))
            fi

            local probe_name
            probe_name="garth-doctor-claude-probe-$$-$(garth_now_epoch)"
            if docker run -d --name "$probe_name" -it \
              --read-only \
              --tmpfs /tmp:rw,noexec,nosuid,size=256m \
              --tmpfs /home/agent:rw,exec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.cache:rw,noexec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.local:rw,exec,nosuid,size=256m,uid=1001,gid=1001,mode=0700 \
              "${claude_mount_args[@]}" \
              --env HOME=/home/agent \
              --env XDG_CACHE_HOME=/home/agent/.cache \
              --env XDG_CONFIG_HOME=/home/agent/.config \
              --env XDG_STATE_HOME=/home/agent/.local/state \
              --env PATH=/home/agent/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
              "$claude_image" \
              bash -lc "eval ${preamble_escaped}; claude" >/dev/null 2>&1; then
              sleep 5
              local probe_logs probe_logs_plain probe_logs_compact
              probe_logs=$(docker logs --tail 220 "$probe_name" 2>&1 || true)
              probe_logs_plain=$(printf '%s\n' "$probe_logs" | sed -E $'s/\x1B\\[[0-9;?]*[ -/]*[@-~]//g; s/\r//g')
              probe_logs_compact=$(printf '%s\n' "$probe_logs_plain" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]\n')
              if printf '%s\n' "$probe_logs_compact" | grep -Eq 'selectloginmethod|openingbrowsertosignin|choosethetextstyle|letsgetstarted|accessingworkspace|yesitrustthisfolder'; then
                garth_log_error "Deep check failed: Claude startup entered onboarding/login/trust flow"
                failures=$((failures + 1))
              elif printf '%s\n' "$probe_logs_compact" | grep -Eq 'installmethodisnative|nativeinstallationexistsbut'; then
                garth_log_error "Deep check failed: Claude startup reported native install layout mismatch"
                failures=$((failures + 1))
              else
                garth_log_success "Deep check passed: Claude startup avoided onboarding/login/trust/install prompts"
              fi
              docker rm -f "$probe_name" >/dev/null 2>&1 || true
            else
              garth_log_warn "Deep check skipped: unable to start interactive Claude probe container"
              warnings=$((warnings + 1))
            fi
          fi
        fi
      else
        garth_log_info "Skipping Claude deep checks: 'claude' not enabled in defaults.auth_passthrough"
      fi
    fi
  fi

  if ((failures > 0)); then
    garth_log_error "Doctor found ${failures} failing check(s) and ${warnings} warning(s)"
    return 1
  fi

  if ((warnings > 0)); then
    garth_log_warn "Doctor found 0 failures and ${warnings} warning(s)"
  else
    garth_log_success "Doctor found 0 failures and 0 warnings"
  fi
  return 0
}

main() {
  local command="${1:-}"
  if [[ -z "$command" ]]; then
    usage
    exit 1
  fi
  shift || true

  case "$command" in
    boot) cmd_boot "$@" ;;
    worktree) cmd_worktree "$@" ;;
    agent) cmd_agent "$@" ;;
    token) cmd_token "$@" ;;
    doctor) cmd_doctor "$@" ;;
    status) cmd_status "$@" ;;
    stop) cmd_stop "$@" ;;
    setup) cmd_setup "$@" ;;
    internal-refresh) cmd_internal_refresh "$@" ;;
    --help|-h|help) usage ;;
    *)
      garth_die "Unknown command: $command" 1
      ;;
  esac
}

main "$@"
