#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  LINK_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$LINK_DIR/$SOURCE_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
GARTH_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$GARTH_ROOT/lib/common.sh"
source "$GARTH_ROOT/lib/git.sh"
source "$GARTH_ROOT/lib/session.sh"
source "$GARTH_ROOT/lib/secrets.sh"
source "$GARTH_ROOT/lib/github-app.sh"
source "$GARTH_ROOT/lib/container.sh"
source "$GARTH_ROOT/lib/zellij.sh"
source "$GARTH_ROOT/lib/workspace.sh"

garth_install_cleanup_trap

GARTH_STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/garth"
# Config resolution: explicit override > repo-root config.toml > XDG path.
if [[ -n "${GARTH_CONFIG_PATH:-}" ]]; then
  : # explicit override
elif [[ -f "$GARTH_ROOT/config.toml" ]]; then
  GARTH_CONFIG_PATH="$GARTH_ROOT/config.toml"
else
  GARTH_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/garth/config.toml"
fi
GARTH_BIN_PATH="$SCRIPT_DIR/garth"

if garth_is_macos && [[ -x "/opt/homebrew/bin/python3" ]]; then
  export PATH="/opt/homebrew/bin:$PATH"
fi

usage() {
  local version
  version="$(cat "$GARTH_ROOT/VERSION" 2>/dev/null || echo "unknown")"
  cat << USAGE
garth $version — workspace orchestrator for autonomous coding agents

Usage: garth <command> [options]

Workspace lifecycle:
  new <dir> <name>        Create a new branch, worktree, and session
  open <id>               Resume a session by ID (or use -d/--dir for branch)
  up <dir> [flags]        Interactive wizard (or explicit flags) to launch

Session management:
  ps [-q]                 List all sessions with status
  stop <id>               Stop a session (preserves worktree and state)
  down <id> [-y]          Remove a session and all its resources
  containers <id>         List Docker container IDs for a session

Other:
  agent <dir> [name]      Run one or more agents in docker or host mode
  agent <dir> [name]      Run one or more agents in docker or host mode
  refresh-images          Rebuild Docker images with pull + no-cache
  token <dir>             Mint a GitHub App installation token
  doctor [--repo <dir>] [--deep] [--skip-token]
                          Diagnose local setup and auth health
  setup                   First-time setup helper

Run 'garth <command> --help' for command-specific options.
USAGE
}

config_env() {
  garth_python "$GARTH_ROOT/lib/config-parser.py" env "$GARTH_CONFIG_PATH"
}

load_config() {
  [[ -f "$GARTH_CONFIG_PATH" ]] || garth_die "Config not found: $GARTH_CONFIG_PATH" 1
  eval "$(config_env)"
}

agent_exists() {
  local agent="$1"
  local key
  key=$(garth_agent_key "$agent")
  local var="GARTH_AGENT_${key}_BASE_COMMAND"
  [[ -n "${!var:-}" ]]
}

csv_to_array() {
  local csv="$1"
  if [[ -z "$csv" ]]; then
    return 0
  fi
  IFS=',' read -r -a _GARTH_ARRAY_OUT <<< "$csv"
}

csv_contains_token() {
  local csv="$1"
  local token="$2"
  [[ -n "$csv" && -n "$token" ]] || return 1
  case ",$csv," in
    *",$token,"*) return 0 ;;
    *) return 1 ;;
  esac
}

resolve_agents() {
  local requested_csv="$1"
  local csv="$requested_csv"
  if [[ -z "$csv" ]]; then
    csv="$GARTH_DEFAULTS_AGENTS_CSV"
  fi

  csv_to_array "$csv"
  local -a raw_agents=("${_GARTH_ARRAY_OUT[@]:-}")
  local -a normalized_agents=()
  local agent
  for agent in "${raw_agents[@]:-}"; do
    agent="${agent// /}"
    [[ -n "$agent" ]] || continue
    agent_exists "$agent" || garth_die "Unknown agent in selection: $agent" 1
    normalized_agents+=("$agent")
  done

  GARTH_SELECTED_AGENTS=("${normalized_agents[@]:-}")
  [[ ${#GARTH_SELECTED_AGENTS[@]} -gt 0 ]] || garth_die "No agents selected" 1
}

garth_has_local_claude_auth() {
  local claude_json="$HOME/.claude.json"
  if [[ -f "$claude_json" ]]; then
    if garth_python - "$claude_json" >/dev/null 2>&1 << 'PY'; then
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    obj = json.loads(path.read_text(encoding="utf-8", errors="replace"))
except Exception:
    raise SystemExit(1)

if isinstance(obj, dict):
    oauth = obj.get("oauthAccount")
    if isinstance(oauth, dict) and oauth:
        raise SystemExit(0)
    if obj.get("firstStartTime"):
        raise SystemExit(0)

raise SystemExit(2)
PY
      return 0
    fi
  fi

  local backup
  for backup in \
    "$HOME/.claude/backups/.claude.json.backup."* \
    "$HOME/.claude/backups/.claude.json.corrupted."*; do
    if [[ -f "$backup" ]]; then
      return 0
    fi
  done

  return 1
}

garth_has_local_codex_auth() {
  local candidate
  for candidate in \
    "$HOME/.codex/auth.json" \
    "$HOME/.codex/tokens.json" \
    "$HOME/.codex/credentials.json" \
    "$HOME/.config/codex/auth.json"; do
    if [[ -f "$candidate" ]]; then
      return 0
    fi
  done
  return 1
}

garth_agent_has_local_cli_auth() {
  local agent="$1"
  case "$agent" in
    claude) garth_has_local_claude_auth ;;
    codex) garth_has_local_codex_auth ;;
    *) return 1 ;;
  esac
}

token_cache_dir() {
  echo "$GARTH_STATE_ROOT/token-cache"
}

token_cache_file_for_owner_repo() {
  local owner_repo="$1"
  local key
  key=$(echo "$owner_repo" | sed -E 's/[^A-Za-z0-9._-]+/_/g')
  echo "$(token_cache_dir)/${key}.tsv"
}

garth_read_cached_token_for_owner_repo() {
  local owner_repo="$1"
  local cache_file
  cache_file=$(token_cache_file_for_owner_repo "$owner_repo")
  [[ -f "$cache_file" ]] || return 1

  local token expires_at expires_epoch installation_id
  IFS=$'\t' read -r token expires_at expires_epoch installation_id < "$cache_file" || return 1
  [[ -n "$token" && -n "$expires_at" && -n "$expires_epoch" ]] || return 1
  [[ "$expires_epoch" =~ ^[0-9]+$ ]] || return 1

  local now min_ttl
  now=$(garth_now_epoch)
  min_ttl="${GARTH_TOKEN_CACHE_MIN_TTL_SECONDS:-}"
  if [[ -z "$min_ttl" ]]; then
    if [[ -n "${GARTH_TOKEN_REFRESH_LEAD_TIME:-}" ]]; then
      local lead_seconds
      lead_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_LEAD_TIME" 2>/dev/null || true)
      if [[ "$lead_seconds" =~ ^[0-9]+$ ]] && (( lead_seconds > 0 )); then
        min_ttl="$lead_seconds"
      fi
    fi
  fi
  if [[ -z "$min_ttl" || ! "$min_ttl" =~ ^[0-9]+$ ]]; then
    min_ttl=900
  fi
  if (( expires_epoch <= now + min_ttl )); then
    return 1
  fi

  printf '%s\t%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" "$owner_repo"
}

garth_write_cached_token_for_owner_repo() {
  local owner_repo="$1"
  local token="$2"
  local expires_at="$3"
  local expires_epoch="$4"
  local installation_id="$5"
  local cache_dir cache_file tmp_file

  cache_dir=$(token_cache_dir)
  mkdir -p "$cache_dir"
  chmod 700 "$cache_dir"

  cache_file=$(token_cache_file_for_owner_repo "$owner_repo")
  tmp_file="${cache_file}.tmp.$$"
  umask 077
  printf '%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" > "$tmp_file"
  chmod 600 "$tmp_file"
  mv "$tmp_file" "$cache_file"
}

mint_token_for_repo() {
  local repo_root="$1"
  local remote_url owner_repo

  remote_url=$(garth_git_remote_url "$repo_root" "origin")
  owner_repo=$(garth_git_owner_repo_from_remote "$remote_url") || \
    garth_die "Unsupported remote URL format (expected GitHub): $remote_url" 1

  local cached
  if cached=$(garth_read_cached_token_for_owner_repo "$owner_repo" 2>/dev/null); then
    printf '%s\n' "$cached"
    return 0
  fi

  # Ensure interactive signin (when needed) happens in the parent shell.
  garth_require_op

  local minted
  minted=$(garth_github_mint_installation_token "$owner_repo") || \
    garth_die "Failed to mint GitHub token. Check 1Password sign-in and GitHub App config." 3

  local token expires_at installation_id
  IFS=$'\t' read -r token expires_at installation_id <<< "$minted"
  [[ -n "$token" && -n "$expires_at" ]] || garth_die "Failed to mint GitHub token" 3

  local expires_epoch
  expires_epoch=$(garth_iso8601_to_epoch "$expires_at")
  garth_write_cached_token_for_owner_repo "$owner_repo" "$token" "$expires_at" "$expires_epoch" "$installation_id"

  printf '%s\t%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" "$owner_repo"
}

compute_profile_name() {
  local repo_name="$1"
  local branch="$2"
  local slug
  slug=$(garth_slugify_branch "$branch")
  echo "${repo_name}-${slug}"
}

sleep_with_session_guard() {
  local seconds="$1"
  local session_dir="$2"
  local i
  for ((i = 0; i < seconds; i++)); do
    [[ -f "$session_dir/active" ]] || return 1
    sleep 1
  done
  return 0
}

garth_is_sensitive_changed_path() {
  local path="$1"
  case "$path" in
    .git/hooks/*|.git/config|.github/*|Makefile|*.sh|.circleci/*|.gitlab-ci.yml|Jenkinsfile)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

garth_post_session_report() {
  local session="$1"
  local session_dir="$2"
  local worktree="$3"

  [[ -n "$worktree" ]] || return 0
  if ! git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  local diff_stat
  diff_stat=$(git -C "$worktree" diff --stat 2>/dev/null || true)
  if [[ -n "$diff_stat" ]]; then
    garth_log_info "Post-session diff summary ($session):"
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      echo "  $line"
    done <<< "$diff_stat"
  fi

  local -a changed_paths=()
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    changed_paths+=("$path")
  done < <(
    {
      git -C "$worktree" diff --name-only
      git -C "$worktree" diff --cached --name-only
      git -C "$worktree" ls-files --others --exclude-standard
    } 2>/dev/null | sed '/^$/d' | sort -u
  )

  local -a sensitive_paths=()
  local path
  for path in "${changed_paths[@]:-}"; do
    if garth_is_sensitive_changed_path "$path"; then
      sensitive_paths+=("$path")
    fi
  done

  if [[ ${#sensitive_paths[@]} -gt 0 ]]; then
    local sensitive_csv
    sensitive_csv=$(garth_join_by "," "${sensitive_paths[@]}")
    garth_log_warn "Sensitive paths changed in session '$session': $sensitive_csv"
    garth_audit_log "$session_dir" "post_session_change_report" \
      "session=$session" \
      "worktree=$worktree" \
      "sensitive_paths_csv=$sensitive_csv" \
      "sensitive_count=${#sensitive_paths[@]}"
  else
    garth_audit_log "$session_dir" "post_session_change_report" \
      "session=$session" \
      "worktree=$worktree" \
      "sensitive_count=0"
  fi
}

garth_launch_workspace() {
  local dir=""
  local agents_csv=""
  local auth_passthrough_csv=""
  local network=""
  local sandbox=""
  local workspace=""
  local safety_mode=""
  local session_override=""
  local session_id_override=""
  local worktree_managed="false"
  local worktree_state="reused"
  local session_state="new"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agents)
        agents_csv="$2"
        shift 2
        ;;
      --auth-passthrough)
        auth_passthrough_csv="$2"
        shift 2
        ;;
      --network)
        network="$2"
        shift 2
        ;;
      --sandbox)
        sandbox="$2"
        shift 2
        ;;
      --no-sandbox)
        sandbox="none"
        shift
        ;;
      --workspace)
        workspace="$2"
        shift 2
        ;;
      --safety)
        safety_mode="$2"
        shift 2
        ;;
      --session-name)
        session_override="$2"
        shift 2
        ;;
      --session-id)
        session_id_override="$2"
        shift 2
        ;;
      --worktree-managed)
        worktree_managed="$2"
        shift 2
        ;;
      --worktree-state)
        worktree_state="$2"
        shift 2
        ;;
      --session-state)
        session_state="$2"
        shift 2
        ;;
      --dry-run)
        GARTH_DRY_RUN=true
        shift
        ;;
      --yes|-y)
        GARTH_YES=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth launch-workspace <dir> [internal options]

Options:
  --agents <a,b>              Comma-separated agents
  --auth-passthrough <a,b>    Docker auth passthrough for selected agents (opt-in, reduced isolation)
  --sandbox docker|none       Runtime sandbox mode
  --no-sandbox                Alias for --sandbox none
  --network bridge|none       Docker network mode
  --workspace <N|auto>        Move windows to AeroSpace workspace N, or auto-select next (max+1)
  --safety safe|permissive    Agent argument preset
  --dry-run                   Print commands without executing
  --yes, -y                   Auto-confirm prompts
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown launch option: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done

  [[ -n "$dir" ]] || garth_die "launch requires <dir>" 1

  load_config
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    ensure_state_root
  fi

  sandbox="${sandbox:-$GARTH_DEFAULTS_SANDBOX}"
  network="${network:-$GARTH_DEFAULTS_NETWORK}"
  workspace="${workspace:-$GARTH_DEFAULTS_WORKSPACE}"
  safety_mode="${safety_mode:-$GARTH_DEFAULTS_SAFETY_MODE}"
  auth_passthrough_csv="${auth_passthrough_csv:-$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV}"

  csv_to_array "$auth_passthrough_csv"
  local normalized_passthrough=()
  local passthrough_agent
  for passthrough_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
    passthrough_agent="${passthrough_agent// /}"
    [[ -n "$passthrough_agent" ]] || continue
    normalized_passthrough+=("$passthrough_agent")
  done
  auth_passthrough_csv=$(garth_join_by "," "${normalized_passthrough[@]:-}")

  [[ "$sandbox" == "docker" || "$sandbox" == "none" ]] || garth_die "Invalid sandbox mode: $sandbox" 1
  [[ "$network" == "bridge" || "$network" == "none" ]] || garth_die "Invalid network mode: $network" 1
  [[ "$safety_mode" == "safe" || "$safety_mode" == "permissive" ]] || garth_die "Invalid safety mode: $safety_mode" 1

  resolve_agents "$agents_csv"

  if [[ "$sandbox" == "docker" && -n "$auth_passthrough_csv" ]]; then
    garth_log_warn "Docker auth passthrough is enabled for: $auth_passthrough_csv"
    garth_log_warn "This weakens isolation by exposing local CLI auth state to containers."
  fi

  if [[ "$GARTH_DRY_RUN" != "true" && "$sandbox" == "docker" ]]; then
    garth_require_cmd docker
    local image_agent
    for image_agent in "${GARTH_SELECTED_AGENTS[@]}"; do
      garth_ensure_agent_image_ready "$image_agent" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" || \
        garth_die "Docker image setup failed for agent '$image_agent'" 1
    done
  fi
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_require_cmd zellij
  fi

  local abs_dir repo_root branch repo_name session session_dir session_id
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1
  branch=$(garth_git_current_branch "$repo_root")
  repo_name=$(garth_git_repo_name "$repo_root")
  if [[ -n "$session_override" ]]; then
    session="$session_override"
  else
    session=$(garth_git_session_name "$repo_name" "$branch")
    if [[ "$(garth_zellij_session_state "$session")" != "missing" ]]; then
      local base_session="$session"
      local n=2
      while [[ "$(garth_zellij_session_state "${base_session}-${n}")" != "missing" ]]; do
        n=$((n + 1))
      done
      session="${base_session}-${n}"
      garth_log_warn "Reusing session name is unavailable; using $session"
    fi
  fi
  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    session_dir=$(garth_make_temp_dir)
    session_id="${session_id_override:-dryrun}"
  else
    session_dir=$(session_dir_for "$session")

    if [[ -d "$session_dir" ]]; then
      if [[ -f "$session_dir/active" ]]; then
        local zellij_state
        zellij_state=$(garth_zellij_session_state "$session")
        if [[ "$zellij_state" == "running" ]]; then
          garth_die "Session already exists: $session (use 'garth stop $session' first)" 1
        fi
        garth_log_warn "Found stale active state for $session; cleaning it up"
        stop_session "$session"
      fi
    fi

    mkdir -p "$session_dir"
    chmod 700 "$session_dir"
    session_id="${session_id_override:-$(read_state_value "$session_dir" "id")}"
    if [[ -z "$session_id" ]]; then
      session_id=$(garth_session_generate_id)
    fi
  fi

  local token expires_at expires_epoch installation_id owner_repo
  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    owner_repo=$(garth_git_owner_repo_from_remote "$(garth_git_remote_url "$repo_root" origin)") || \
      garth_die "Unsupported remote URL format (expected GitHub)" 1
    token="GARTH_DRY_RUN_TOKEN"
    expires_at="2099-01-01T00:00:00Z"
    expires_epoch="4070908800"
    installation_id="dry-run"
  else
    local minted_file
    minted_file=$(mktemp "${TMPDIR:-/tmp}/garth-minted-token.XXXXXX") || return 1
    garth_register_cleanup_path "$minted_file"
    if ! mint_token_for_repo "$repo_root" > "$minted_file"; then
      garth_audit_log "$session_dir" "token_mint_failure" \
        "session=$session" \
        "repo_root=$repo_root"
      return 3
    fi
    IFS=$'\t' read -r token expires_at expires_epoch installation_id owner_repo < "$minted_file"
  fi

  local token_file
  token_file=$(garth_write_token_file "$session_dir" "$token")
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_audit_log "$session_dir" "token_mint_success" \
      "session=$session" \
      "owner_repo=$owner_repo" \
      "installation_id=$installation_id" \
      "token=$token" \
      "token_expires_at=$expires_at"
  fi

  local agent
  for agent in "${GARTH_SELECTED_AGENTS[@]}"; do
    if [[ "$GARTH_DRY_RUN" == "true" ]]; then
      local api_key_env env_file
      api_key_env=$(garth_agent_field "$agent" "API_KEY_ENV")
      env_file="$session_dir/agent-${agent}.env"
      umask 077
      {
        printf 'TERM=xterm-256color\n'
        printf 'GARTH_GITHUB_TOKEN_FILE=/run/garth/github_token\n'
        printf '%s=%s\n' "$api_key_env" "GARTH_DRY_RUN_API_KEY"
      } > "$env_file"
      chmod 600 "$env_file"
    else
      local require_api_key=true
      if [[ "$sandbox" == "none" ]] || csv_contains_token "$auth_passthrough_csv" "$agent"; then
        require_api_key=false
      fi
      garth_prepare_agent_env_file "$session_dir" "$agent" "$require_api_key" >/dev/null || return 3
    fi
  done

  local layout_file="$session_dir/layout.kdl"
  garth_generate_zellij_layout "$layout_file" "$abs_dir" "$session" "$repo_root" "$session_dir" "$network" \
    "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" "$safety_mode" "$sandbox" "$auth_passthrough_csv" "${GARTH_SELECTED_AGENTS[@]}"

  local agents_csv_effective
  agents_csv_effective=$(garth_join_by "," "${GARTH_SELECTED_AGENTS[@]}")

  garth_log_info "Repo:      $repo_name (${owner_repo})"
  garth_log_info "Branch:    $branch"
  if [[ "$worktree_state" == "none" ]]; then
    garth_log_info "Worktree:  - (none)"
  else
    garth_log_info "Worktree:  $(basename "$abs_dir") (${worktree_state})"
  fi
  garth_log_info "Session:   $session  $session_id  ($session_state)"
  garth_log_info "Agents:    $agents_csv_effective"

  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    garth_log_info "[dry-run] skipping persistent session state writes"
  else
    write_state_value "$session_dir" "active" "1"
    rm -f "$session_dir/stopped_epoch"
    write_state_value "$session_dir" "id" "$session_id"
    write_state_value "$session_dir" "session" "$session"
    write_state_value "$session_dir" "repo_root" "$repo_root"
    write_state_value "$session_dir" "worktree" "$abs_dir"
    write_state_value "$session_dir" "worktree_managed" "$worktree_managed"
    write_state_value "$session_dir" "branch" "$branch"
    write_state_value "$session_dir" "owner_repo" "$owner_repo"
    write_state_value "$session_dir" "agents_csv" "$agents_csv_effective"
    write_state_value "$session_dir" "token_state" "ok"
    write_state_value "$session_dir" "token_expires_at" "$expires_at"
    write_state_value "$session_dir" "token_expires_epoch" "$expires_epoch"
    write_state_value "$session_dir" "started_epoch" "$(garth_now_epoch)"
    write_state_value "$session_dir" "sandbox" "$sandbox"
    write_state_value "$session_dir" "network" "$network"
    write_state_value "$session_dir" "safety_mode" "$safety_mode"
    write_state_value "$session_dir" "installation_id" "$installation_id"
    write_state_value "$session_dir" "token_file" "$token_file"
    garth_audit_log "$session_dir" "session_start" \
      "session=$session" \
      "session_id=$session_id" \
      "repo_root=$repo_root" \
      "worktree=$abs_dir" \
      "branch=$branch" \
      "agents=$agents_csv_effective" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode" \
      "owner_repo=$owner_repo" \
      "installation_id=$installation_id" \
      "token_expires_at=$expires_at"
    if [[ -n "$auth_passthrough_csv" ]]; then
      garth_audit_log "$session_dir" "auth_passthrough_enabled" \
        "session=$session" \
        "auth_passthrough=$auth_passthrough_csv"
    fi

    if [[ "$GARTH_TOKEN_REFRESH_ENABLED" == "true" ]]; then
      "$GARTH_BIN_PATH" internal-refresh \
        --repo-root "$repo_root" \
        --session "$session" \
        --session-dir "$session_dir" >/dev/null 2>&1 &
      write_state_value "$session_dir" "refresher_pid" "$!"
      garth_audit_log "$session_dir" "token_refresher_started" \
        "session=$session" \
        "refresher_pid=$!"
    fi
  fi

  local github_url
  github_url=$(garth_git_https_url_from_remote "$(garth_git_remote_url "$repo_root" origin)")

  local profile_name
  profile_name=$(compute_profile_name "$repo_name" "$branch")

  if [[ "${GARTH_SKIP_GUI:-false}" == "true" ]]; then
    garth_log_warn "GARTH_SKIP_GUI=true; skipping workspace/Cursor/Chrome launch steps"
  else
    garth_move_windows_to_workspace "$workspace"
    if [[ "${GARTH_SKIP_CURSOR:-false}" == "true" ]]; then
      garth_log_warn "GARTH_SKIP_CURSOR=true; skipping Cursor launch steps"
    else
      garth_configure_cursor_terminal_bridge "$abs_dir" "$sandbox"
      garth_launch_cursor "$abs_dir"
    fi
    if [[ "${GARTH_SKIP_CHROME:-false}" == "true" ]]; then
      garth_log_warn "GARTH_SKIP_CHROME=true; skipping Chrome launch"
    else
      garth_launch_chrome_profile "$GARTH_CHROME_PROFILES_DIR" "$profile_name" "$github_url"
    fi
  fi

  garth_log_info "Starting zellij session: $session"
  if ! garth_zellij_launch "$session" "$layout_file"; then
    garth_audit_log "$session_dir" "container_start_failure" \
      "session=$session" \
      "reason=zellij_launch_failed"
    return 1
  fi
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_audit_log "$session_dir" "container_start" \
      "session=$session" \
      "agents=$agents_csv_effective" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode"
  fi

  # If session no longer exists after detach/exit, clean stale session state.
  if [[ "$GARTH_DRY_RUN" != "true" && "$GARTH_ZELLIJ_LAUNCH_ASYNC" == "true" ]]; then
    local _wait
    for _wait in 1 2 3 4 5; do
      if garth_zellij_list_sessions | grep -qx "$session"; then
        break
      fi
      sleep 1
    done
  fi

  if [[ "$GARTH_DRY_RUN" != "true" ]] && ! garth_zellij_list_sessions | grep -qx "$session"; then
    garth_log_warn "zellij session did not start: $session"
    garth_log_warn "If your terminal launcher failed, run manually:"
    if garth_zellij_session_exists "$session"; then
      garth_log_warn "  zellij attach \"$session\""
    else
      garth_log_warn "  zellij -s \"$session\" --new-session-with-layout \"$layout_file\""
    fi
    garth_audit_log "$session_dir" "session_start_failure" \
      "session=$session" \
      "reason=session_not_running_after_launch"
    stop_session "$session"
  fi
}

garth_branch_exists_local() {
  local repo_root="$1"
  local branch="$2"
  git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"
}

garth_branch_exists_remote() {
  local repo_root="$1"
  local remote="$2"
  local branch="$3"
  git -C "$repo_root" show-ref --verify --quiet "refs/remotes/$remote/$branch"
}

garth_list_remotes_for_branch() {
  local repo_root="$1"
  local branch="$2"
  git -C "$repo_root" for-each-ref --format='%(refname:short)' "refs/remotes/*/$branch" | sed -E "s#/$branch\$##" | sort -u
}

garth_print_branch_suggestions() {
  local repo_root="$1"
  local needle="$2"
  local suggestions
  suggestions=$(git -C "$repo_root" for-each-ref --format='%(refname:short)' refs/heads refs/remotes | sed 's#^origin/HEAD$##' | sed '/^$/d' | grep -F "$needle" | head -n 8 || true)
  if [[ -n "$suggestions" ]]; then
    echo "Did you mean:" >&2
    while IFS= read -r s; do
      [[ -n "$s" ]] || continue
      echo "  - ${s#origin/}" >&2
    done <<< "$suggestions"
  fi
}

garth_resolve_existing_branch() {
  local repo_root="$1"
  local branch="$2"
  local remote_override="$3"

  if garth_branch_exists_local "$repo_root" "$branch"; then
    echo "$branch"
    return 0
  fi

  git -C "$repo_root" fetch --all --prune >/dev/null 2>&1 || true

  local -a remotes=()
  local r
  while IFS= read -r r; do
    [[ -n "$r" ]] || continue
    remotes+=("$r")
  done < <(garth_list_remotes_for_branch "$repo_root" "$branch")

  if [[ ${#remotes[@]} -eq 0 ]]; then
    garth_print_branch_suggestions "$repo_root" "$branch"
    garth_die "Branch not found locally or on remotes: $branch" 1
  fi

  local chosen_remote=""
  if [[ -n "$remote_override" ]]; then
    local found=false
    for r in "${remotes[@]}"; do
      if [[ "$r" == "$remote_override" ]]; then
        found=true
        chosen_remote="$remote_override"
        break
      fi
    done
    if [[ "$found" != "true" ]]; then
      garth_die "Branch '$branch' was not found on remote '$remote_override'" 1
    fi
  elif [[ ${#remotes[@]} -eq 1 ]]; then
    chosen_remote="${remotes[0]}"
  else
    local has_origin=false
    for r in "${remotes[@]}"; do
      if [[ "$r" == "origin" ]]; then
        has_origin=true
      fi
    done
    if [[ "$has_origin" == "true" ]]; then
      chosen_remote="origin"
    else
      garth_die "Branch '$branch' exists on multiple remotes (${remotes[*]}). Use --remote <name>." 1
    fi
  fi

  if ! garth_branch_exists_local "$repo_root" "$branch"; then
    git -C "$repo_root" branch --track "$branch" "$chosen_remote/$branch" >/dev/null 2>&1 || true
  fi
  if ! garth_branch_exists_local "$repo_root" "$branch"; then
    garth_die "Failed to create local tracking branch '$branch' from '$chosen_remote/$branch'" 1
  fi
  echo "$branch"
}

garth_unique_session_name() {
  local repo_name="$1"
  local branch="$2"
  local base session n
  base=$(garth_git_session_name "$repo_name" "$branch")
  session="$base"
  n=2
  while [[ -d "$(session_dir_for "$session")" ]] || [[ "$(garth_zellij_session_state "$session")" != "missing" ]]; do
    session="${base}-${n}"
    n=$((n + 1))
  done
  echo "$session"
}

garth_find_session_dir_by_name() {
  local name="$1"
  local dir
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    if [[ "$(garth_session_name_for_dir "$dir")" == "$name" ]]; then
      echo "$dir"
      return 0
    fi
  done < <(garth_session_list_dirs)
  return 1
}

garth_best_session_for_branch() {
  local repo_root="$1"
  local branch="$2"
  local dir status_line status live_candidate stopped_candidate
  live_candidate=""
  stopped_candidate=""

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    status_line=$(garth_session_status_line "$dir")
    status="${status_line#*$'\t'}"
    case "$status" in
      running*|detached)
        if [[ -z "$live_candidate" ]]; then
          live_candidate="$dir"
        fi
        ;;
      stopped)
        if [[ -z "$stopped_candidate" ]]; then
          stopped_candidate="$dir"
        fi
        ;;
    esac
  done < <(garth_sort_session_dirs_by_started < <(garth_find_sessions_for_branch "$repo_root" "$branch"))

  if [[ -n "$live_candidate" ]]; then
    echo "$live_candidate"
  elif [[ -n "$stopped_candidate" ]]; then
    echo "$stopped_candidate"
  fi
}

garth_attach_if_running() {
  local session_dir="$1"
  [[ -n "$session_dir" ]] || return 1
  local session
  session=$(garth_session_name_for_dir "$session_dir")
  if [[ "$(garth_zellij_session_state "$session")" == "running" ]]; then
    garth_log_info "Reattaching session: $session ($(garth_session_id_for_dir "$session_dir"))"
    garth_zellij_launch "$session" "$session_dir/layout.kdl"
    return 0
  fi
  return 1
}

cmd_new() {
  local dir=""
  local branch=""
  local base_ref=""
  local no_worktree=false
  local -a forward=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --base)
        base_ref="$2"
        shift 2
        ;;
      --no-worktree)
        no_worktree=true
        shift
        ;;
      --dry-run|--yes|-y|--agents|--auth-passthrough|--sandbox|--no-sandbox|--network|--workspace|--safety)
        forward+=("$1")
        if [[ "$1" == "--dry-run" || "$1" == "--no-sandbox" || "$1" == "--yes" || "$1" == "-y" ]]; then
          shift
        else
          forward+=("$2")
          shift 2
        fi
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth new <dir> <name> [options]

Create a new branch, worktree, and session. Everything is derived from <name>.

Arguments:
  <dir>                   Path to the git repository
  <name>                  Name for the new branch (must not already exist)

Options:
  --base <ref>            Base ref for the new branch (default: repo default branch)
  --no-worktree           Create branch in-place instead of a worktree
  --agents <a,b>          Comma-separated agents (overrides config)
  --auth-passthrough <a,b>
                          Docker auth passthrough for selected agents
  --sandbox docker|none   Runtime sandbox mode
  --no-sandbox            Alias for --sandbox none
  --network bridge|none   Docker network mode
  --safety safe|permissive
                          Agent argument preset
  --workspace <N|auto>    AeroSpace workspace
  --dry-run               Print commands without executing
  --yes, -y               Auto-confirm prompts

Examples:
  garth new . feature/auth          Create feature/auth from default branch
  garth new . hotfix --base v2.1    Create hotfix from v2.1 tag
HELP
        return 0
        ;;
      -*)
        garth_die "Unknown option for new: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
        elif [[ -z "$branch" ]]; then
          branch="$1"
        else
          garth_die "Unexpected argument: $1" 1
        fi
        shift
        ;;
    esac
  done

  [[ -n "$dir" && -n "$branch" ]] || garth_die "new requires <dir> <name>" 1
  load_config

  local abs_dir repo_root repo_name session session_id target_dir
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1

  if garth_branch_exists_local "$repo_root" "$branch" || git -C "$repo_root" for-each-ref --format='%(refname)' "refs/remotes/*/$branch" | grep -q .; then
    garth_die "Branch already exists: $branch (use 'garth open -d $dir $branch')" 1
  fi

  base_ref="${base_ref:-$(garth_git_default_branch "$repo_root")}"
  if ! git -C "$repo_root" rev-parse --verify --quiet "${base_ref}^{commit}" >/dev/null; then
    echo "Base ref '$base_ref' was not found. Available branches:" >&2
    git -C "$repo_root" for-each-ref --format='  - %(refname:short)' refs/heads refs/remotes >&2 || true
    exit 1
  fi

  repo_name=$(garth_git_repo_name "$repo_root")
  session=$(garth_unique_session_name "$repo_name" "$branch")
  session_id=$(garth_session_generate_id)

  if [[ "$no_worktree" == "true" ]]; then
    git -C "$repo_root" checkout -b "$branch" "$base_ref" >/dev/null
    target_dir="$repo_root"
    garth_launch_workspace "$target_dir" \
      --session-name "$session" \
      --session-id "$session_id" \
      --worktree-managed false \
      --worktree-state none \
      --session-state new \
      ${forward[@]+"${forward[@]}"}
    return 0
  fi

  target_dir=$(garth_git_worktree_path "$repo_root" "$branch")
  mkdir -p "$(dirname "$target_dir")"
  git -C "$repo_root" worktree add "$target_dir" -b "$branch" "$base_ref"
  garth_launch_workspace "$target_dir" \
    --session-name "$session" \
    --session-id "$session_id" \
    --worktree-managed true \
    --worktree-state created \
    --session-state new \
    ${forward[@]+"${forward[@]}"}
}

cmd_open() {
  local dir=""
  local id_prefix=""
  local branch=""
  local remote_name=""
  local no_worktree=false
  local new_worktree=false
  local new_session=false
  local worktree_path=""
  local session_name_override=""
  local -a forward=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--dir)
        [[ -z "$id_prefix" ]] || garth_die "Cannot use <id> with --dir. Use either 'garth open <id>' or 'garth open -d <dir> [branch]'." 1
        dir="$2"
        shift 2
        ;;
      -b|--branch)
        branch="$2"
        shift 2
        ;;
      --remote)
        remote_name="$2"
        shift 2
        ;;
      --no-worktree)
        no_worktree=true
        shift
        ;;
      --new-worktree)
        new_worktree=true
        shift
        ;;
      --new-session)
        new_session=true
        shift
        ;;
      -w|--worktree)
        worktree_path="$2"
        shift 2
        ;;
      -s|--session)
        session_name_override="$2"
        shift 2
        ;;
      --dry-run|--yes|-y|--agents|--auth-passthrough|--sandbox|--no-sandbox|--network|--workspace|--safety)
        forward+=("$1")
        if [[ "$1" == "--dry-run" || "$1" == "--no-sandbox" || "$1" == "--yes" || "$1" == "-y" ]]; then
          shift
        else
          forward+=("$2")
          shift 2
        fi
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth open <id> [options]
       garth open -d <dir> [<branch>] [options]

Resume a session by ID, or open a branch from a git repository.

Arguments:
  <id>                    Session ID or prefix (from garth ps)

Options:
  -d, --dir <dir>         Path to the git repository (use instead of <id>
                          to open by directory and branch)
  -b, --branch <name>     Branch to open (same as positional <branch>)
  --remote <name>         Remote to fetch from when branch is remote-only
                          (default: origin)
  -w, --worktree <path>   Use a specific worktree path
  -s, --session <name>    Reattach to a specific session by name
  --new-worktree          Force creation of a new worktree
  --new-session           Force creation of a new session
  --no-worktree           Open branch in-place (fails if working tree is dirty)
  --agents <a,b>          Comma-separated agents (overrides config)
  --auth-passthrough <a,b>
                          Docker auth passthrough for selected agents
  --sandbox docker|none   Runtime sandbox mode
  --no-sandbox            Alias for --sandbox none
  --network bridge|none   Docker network mode
  --safety safe|permissive
                          Agent argument preset
  --workspace <N|auto>    AeroSpace workspace
  --dry-run               Print commands without executing
  --yes, -y               Auto-confirm prompts

Examples:
  garth open a1b2c3                 Resume session by ID
  garth open -d .                   Open the repo's default branch
  garth open -d . -b feature/auth   Open an existing feature branch
  garth open -d . feature/auth      Open an existing feature branch
  garth open -d . pr-branch --remote upstream
                                    Open a branch from a non-origin remote
HELP
        return 0
        ;;
      -*)
        garth_die "Unknown option for open: $1" 1
        ;;
      *)
        if [[ -n "$dir" ]]; then
          if [[ -z "$branch" ]]; then
            branch="$1"
          else
            garth_die "Unexpected argument: $1" 1
          fi
        elif [[ -z "$id_prefix" ]]; then
          id_prefix="$1"
        else
          garth_die "Unexpected argument: $1" 1
        fi
        shift
        ;;
    esac
  done

  if [[ "$new_session" == "true" && -n "$session_name_override" ]]; then
    garth_die "Conflicting flags: --session and --new-session" 1
  fi

  load_config
  ensure_state_root

  if [[ -n "$id_prefix" ]]; then
    if [[ -n "$branch" || -n "$remote_name" || "$no_worktree" == "true" || "$new_worktree" == "true" || -n "$worktree_path" || -n "$session_name_override" || "$new_session" == "true" ]]; then
      garth_die "Flags --branch, --remote, --no-worktree, --new-worktree, --worktree, --session, and --new-session require --dir." 1
    fi

    local selected_session_dir repo_root target_dir worktree_managed session session_id stored_branch
    selected_session_dir=$(garth_find_session_dir_by_id_prefix "$id_prefix")
    repo_root=$(read_state_value "$selected_session_dir" "repo_root")
    stored_branch=$(read_state_value "$selected_session_dir" "branch")
    target_dir=$(read_state_value "$selected_session_dir" "worktree")
    worktree_managed=$(read_state_value "$selected_session_dir" "worktree_managed")
    [[ -n "$worktree_managed" ]] || worktree_managed="false"

    [[ -n "$repo_root" ]] || garth_die "Session state is missing repo_root for ID $(garth_session_id_for_dir "$selected_session_dir")" 1
    [[ -n "$stored_branch" ]] || garth_die "Session state is missing branch for ID $(garth_session_id_for_dir "$selected_session_dir")" 1
    [[ -d "$repo_root" ]] || garth_die "Session repo no longer exists on disk: $repo_root" 1

    if [[ -n "$selected_session_dir" ]] && garth_attach_if_running "$selected_session_dir"; then
      return 0
    fi

    [[ -n "$target_dir" ]] || target_dir="$repo_root"
    [[ -d "$target_dir" ]] || garth_die "Session worktree no longer exists on disk: $target_dir" 1
    session=$(garth_session_name_for_dir "$selected_session_dir")
    session_id=$(garth_session_id_for_dir "$selected_session_dir")

    local worktree_state
    if [[ "$worktree_managed" == "true" ]]; then
      worktree_state="reused"
    elif [[ "$target_dir" == "$repo_root" ]]; then
      worktree_state="none"
    else
      worktree_state="reused"
    fi

    garth_launch_workspace "$target_dir" \
      --session-name "$session" \
      --session-id "$session_id" \
      --worktree-managed "$worktree_managed" \
      --worktree-state "$worktree_state" \
      --session-state resumed \
      ${forward[@]+"${forward[@]}"}
    return 0
  fi

  [[ -n "$dir" ]] || garth_die "open requires <id> or --dir <dir>" 1

  local abs_dir repo_root repo_name target_branch
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1
  repo_name=$(garth_git_repo_name "$repo_root")
  target_branch="${branch:-$(garth_git_default_branch "$repo_root")}"
  target_branch=$(garth_resolve_existing_branch "$repo_root" "$target_branch" "$remote_name")

  local selected_session_dir=""
  if [[ -n "$session_name_override" ]]; then
    selected_session_dir=$(garth_find_session_dir_by_name "$session_name_override" || true)
    [[ -n "$selected_session_dir" ]] || garth_die "Session not found: $session_name_override" 1
  elif [[ "$new_session" != "true" ]]; then
    selected_session_dir=$(garth_best_session_for_branch "$repo_root" "$target_branch" || true)
  fi

  if [[ -z "$session_name_override" && ( "$new_worktree" == "true" || -n "$worktree_path" || "$no_worktree" == "true" ) ]]; then
    selected_session_dir=""
  fi

  if [[ -n "$selected_session_dir" ]] && garth_attach_if_running "$selected_session_dir"; then
    return 0
  fi

  local session session_id session_state target_dir worktree_state worktree_managed
  session_state="new"
  if [[ -n "$selected_session_dir" && "$new_session" != "true" ]]; then
    session=$(garth_session_name_for_dir "$selected_session_dir")
    session_id=$(garth_session_id_for_dir "$selected_session_dir")
    session_state="resumed"
  else
    session=$(garth_unique_session_name "$repo_name" "$target_branch")
    session_id=$(garth_session_generate_id)
  fi

  worktree_state="reused"
  worktree_managed="false"
  if [[ "$no_worktree" == "true" ]]; then
    if [[ -n "$(git -C "$repo_root" status --porcelain 2>/dev/null || true)" ]]; then
      garth_die "Cannot switch branches in-place with uncommitted changes at '$repo_root'. Commit/stash changes or omit --no-worktree." 1
    fi
    git -C "$repo_root" checkout "$target_branch" >/dev/null
    target_dir="$repo_root"
    worktree_state="none"
  elif [[ -n "$worktree_path" ]]; then
    target_dir=$(garth_abs_path "$worktree_path")
    worktree_managed="false"
  elif [[ "$new_worktree" != "true" && -n "$selected_session_dir" ]]; then
    target_dir=$(read_state_value "$selected_session_dir" "worktree")
    worktree_managed=$(read_state_value "$selected_session_dir" "worktree_managed")
    [[ -n "$worktree_managed" ]] || worktree_managed="false"
    if [[ -z "$target_dir" || ! -d "$target_dir" ]]; then
      target_dir=""
    fi
  else
    target_dir=""
  fi

  if [[ -z "${target_dir:-}" && "$no_worktree" != "true" ]]; then
    if [[ "$new_worktree" != "true" ]]; then
      target_dir=$(garth_git_find_worktree_for_branch "$repo_root" "$target_branch" || true)
      if [[ -n "$target_dir" ]]; then
        worktree_managed="true"
        worktree_state="reused"
      fi
    fi
  fi

  if [[ -z "${target_dir:-}" && "$no_worktree" != "true" ]]; then
    target_dir=$(garth_git_worktree_path "$repo_root" "$target_branch")
    mkdir -p "$(dirname "$target_dir")"
    git -C "$repo_root" worktree add "$target_dir" "$target_branch"
    worktree_managed="true"
    worktree_state="created"
  fi

  garth_launch_workspace "$target_dir" \
    --session-name "$session" \
    --session-id "$session_id" \
    --worktree-managed "$worktree_managed" \
    --worktree-state "$worktree_state" \
    --session-state "$session_state" \
    ${forward[@]+"${forward[@]}"}
}

cmd_up() {
  local dir=""
  local branch=""
  local new_branch=""
  local base_ref=""
  local remote_name=""
  local worktree_path=""
  local session_name=""
  local auto=false
  local auto_branch=false
  local auto_worktree=false
  local auto_session=false
  local new_worktree=false
  local new_session=false
  local no_worktree=false
  local -a forward=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -b|--branch)
        branch="$2"
        shift 2
        ;;
      --new-branch)
        new_branch="$2"
        shift 2
        ;;
      --base)
        base_ref="$2"
        shift 2
        ;;
      --remote)
        remote_name="$2"
        shift 2
        ;;
      -w|--worktree)
        worktree_path="$2"
        shift 2
        ;;
      -s|--session)
        session_name="$2"
        shift 2
        ;;
      --new-worktree)
        new_worktree=true
        shift
        ;;
      --new-session)
        new_session=true
        shift
        ;;
      --auto-branch)
        auto_branch=true
        shift
        ;;
      --auto-worktree)
        auto_worktree=true
        shift
        ;;
      --auto-session)
        auto_session=true
        shift
        ;;
      --auto)
        auto=true
        shift
        ;;
      --no-worktree)
        no_worktree=true
        shift
        ;;
      --dry-run|--yes|-y|--agents|--auth-passthrough|--sandbox|--no-sandbox|--network|--workspace|--safety)
        forward+=("$1")
        if [[ "$1" == "--dry-run" || "$1" == "--no-sandbox" || "$1" == "--yes" || "$1" == "-y" ]]; then
          shift
        else
          forward+=("$2")
          shift 2
        fi
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth up <dir> [options]

Interactive workspace launcher. With no flags, presents a step-by-step wizard
to select a branch, worktree, and session. With explicit flags, skips the
corresponding wizard steps. With --auto, uses wizard defaults non-interactively.

Arguments:
  <dir>                   Path to the git repository

Branch selection (wizard step 1):
  -b, --branch <name>     Use an existing branch (skips step 1)
  --new-branch <name>     Create a new branch (skips step 1)
  --base <ref>            Base ref for --new-branch (default: repo default branch)
  --remote <name>         Remote for remote-only branches (default: origin)
  --auto-branch           Use wizard default: currently checked-out branch

Worktree selection (wizard step 2):
  -w, --worktree <path>   Use a specific worktree path (skips step 2)
  --new-worktree          Force creation of a new worktree (skips step 2)
  --no-worktree           No worktree, boot in-place (skips step 2)
  --auto-worktree         Reuse if exists, create if not (skips step 2)

Session selection (wizard step 3):
  -s, --session <name>    Reattach to a specific session (skips step 3)
  --new-session           Force creation of a new session (skips step 3)
  --auto-session          Resume if exists, create if not (skips step 3)

Shorthand:
  --auto                  Equivalent to --auto-branch --auto-worktree --auto-session

General options:
  --agents <a,b>          Comma-separated agents (overrides config)
  --auth-passthrough <a,b>
                          Docker auth passthrough for selected agents
  --sandbox docker|none   Runtime sandbox mode
  --no-sandbox            Alias for --sandbox none
  --network bridge|none   Docker network mode
  --safety safe|permissive
                          Agent argument preset
  --workspace <N|auto>    AeroSpace workspace
  --dry-run               Print commands without executing
  --yes, -y               Auto-confirm prompts

Examples:
  garth up .                            Full interactive wizard
  garth up . --auto                     Non-interactive, all defaults
  garth up . --branch feature/auth      Skip branch step, wizard for the rest
  garth up . --new-branch fix/bug --base v2.1
                                        Create new branch, wizard for worktree/session
HELP
        return 0
        ;;
      -*)
        garth_die "Unknown option for up: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
        else
          garth_die "Unexpected argument: $1" 1
        fi
        shift
        ;;
    esac
  done

  [[ -n "$dir" ]] || garth_die "up requires <dir>" 1

  if [[ "$auto" == "true" ]]; then
    auto_branch=true
    auto_worktree=true
    auto_session=true
  fi

  if [[ -n "$branch" && -n "$new_branch" ]]; then
    garth_die "Conflicting flags: --branch and --new-branch" 1
  fi

  if [[ -n "$new_branch" ]]; then
    local -a args=("$dir" "$new_branch")
    [[ -n "$base_ref" ]] && args+=(--base "$base_ref")
    [[ "$no_worktree" == "true" ]] && args+=(--no-worktree)
    args+=(${forward[@]+"${forward[@]}"})
    cmd_new "${args[@]}"
    return 0
  fi

  load_config
  local abs_dir repo_root resolved_branch
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1

  resolved_branch="$branch"
  if [[ -z "$resolved_branch" && "$auto_branch" == "true" ]]; then
    resolved_branch=$(garth_git_current_branch "$repo_root")
  fi

  if [[ -z "$resolved_branch" ]]; then
    if ! garth_has_tty; then
      garth_die "Interactive mode requires a terminal. Use --auto or explicit flags." 1
    fi
    local current_branch default_branch answer i
    current_branch=$(garth_git_current_branch "$repo_root")
    default_branch=$(garth_git_default_branch "$repo_root")
    local -a branches_raw=()
    local -a branches=()
    while IFS= read -r i; do
      [[ -n "$i" ]] || continue
      branches_raw+=("$i")
    done < <(git -C "$repo_root" for-each-ref --format='%(refname:short)' refs/heads)

    local has_current=false
    for i in "${branches_raw[@]}"; do
      if [[ "$i" == "$current_branch" ]]; then
        has_current=true
        break
      fi
    done
    if [[ "$has_current" == "true" ]]; then
      branches+=("$current_branch")
      for i in "${branches_raw[@]}"; do
        [[ "$i" == "$current_branch" ]] && continue
        branches+=("$i")
      done
    else
      branches=("${branches_raw[@]}")
    fi

    echo "Branch:"
    local idx=1
    local b
    for b in "${branches[@]}"; do
      local tags=""
      [[ "$b" == "$current_branch" ]] && tags=" * checked out"
      [[ "$b" == "$default_branch" && "$b" != "$current_branch" ]] && tags=" default"
      printf '  %d) %s%s\n' "$idx" "$b" "$tags"
      idx=$((idx + 1))
    done
    read -r -p "[1] > " answer
    if [[ -z "$answer" ]]; then
      resolved_branch="${branches[0]}"
    elif [[ "$answer" =~ ^[0-9]+$ ]] && ((answer >= 1 && answer <= ${#branches[@]})); then
      resolved_branch="${branches[$((answer - 1))]}"
    else
      new_branch="$answer"
      if [[ -z "$base_ref" ]]; then
        local -a base_options=()
        base_options+=("$current_branch")
        if [[ "$default_branch" != "$current_branch" ]]; then
          base_options+=("$default_branch")
        fi
        for b in "${branches[@]}"; do
          local seen=false
          local bo
          for bo in "${base_options[@]}"; do
            if [[ "$bo" == "$b" ]]; then
              seen=true
              break
            fi
          done
          if [[ "$seen" != "true" ]]; then
            base_options+=("$b")
          fi
        done

        echo "Base:"
        local bidx=1
        for b in "${base_options[@]}"; do
          local btags=""
          [[ "$b" == "$current_branch" ]] && btags=" * checked out"
          [[ "$b" == "$default_branch" && "$b" != "$current_branch" ]] && btags=" default"
          printf '  %d) %s%s\n' "$bidx" "$b" "$btags"
          bidx=$((bidx + 1))
        done
        local base_choice
        read -r -p "[1] > " base_choice
        base_choice="${base_choice:-1}"
        if [[ "$base_choice" =~ ^[0-9]+$ ]] && ((base_choice >= 1 && base_choice <= ${#base_options[@]})); then
          base_ref="${base_options[$((base_choice - 1))]}"
        else
          garth_die "Invalid base choice: $base_choice" 1
        fi
      fi
    fi
  fi

  if [[ -n "$new_branch" ]]; then
    local -a args=("$dir" "$new_branch")
    [[ -n "$base_ref" ]] && args+=(--base "$base_ref")
    [[ "$no_worktree" == "true" ]] && args+=(--no-worktree)
    args+=(${forward[@]+"${forward[@]}"})
    cmd_new "${args[@]}"
    return 0
  fi

  if [[ -z "$worktree_path" && "$new_worktree" != "true" && "$no_worktree" != "true" && "$auto_worktree" != "true" ]]; then
    if ! garth_has_tty; then
      garth_die "Interactive mode requires a terminal. Use --auto or explicit flags." 1
    fi
    local existing_worktree worktree_choice
    existing_worktree=$(garth_git_find_worktree_for_branch "$repo_root" "$resolved_branch" || true)
    if [[ -n "$existing_worktree" ]]; then
      echo "Worktree:"
      echo "  1) $(basename "$existing_worktree")      exists"
      echo "  2) New worktree"
      echo "  3) No worktree"
      read -r -p "[1] > " worktree_choice
      worktree_choice="${worktree_choice:-1}"
      case "$worktree_choice" in
        1) worktree_path="$existing_worktree" ;;
        2) new_worktree=true ;;
        3) no_worktree=true ;;
        *) garth_die "Invalid worktree choice: $worktree_choice" 1 ;;
      esac
    else
      echo "Worktree:"
      echo "  1) Create worktree       recommended"
      echo "  2) No worktree"
      read -r -p "[1] > " worktree_choice
      worktree_choice="${worktree_choice:-1}"
      case "$worktree_choice" in
        1) new_worktree=true ;;
        2) no_worktree=true ;;
        *) garth_die "Invalid worktree choice: $worktree_choice" 1 ;;
      esac
    fi
  fi

  if [[ -z "$session_name" && "$new_session" != "true" && "$auto_session" != "true" ]]; then
    if ! garth_has_tty; then
      garth_die "Interactive mode requires a terminal. Use --auto or explicit flags." 1
    fi

    local -a session_dirs=()
    local session_dir
    while IFS= read -r session_dir; do
      [[ -n "$session_dir" ]] || continue
      session_dirs+=("$session_dir")
    done < <(garth_sort_session_dirs_by_started < <(garth_find_sessions_for_branch "$repo_root" "$resolved_branch"))

    echo "Session:"
    if [[ ${#session_dirs[@]} -eq 0 ]]; then
      echo "  1) New session"
      read -r -p "[1] > " _
      new_session=true
    else
      local idx=1
      for session_dir in "${session_dirs[@]}"; do
        local sid sname status_line status
        sid=$(garth_session_id_for_dir "$session_dir")
        sname=$(garth_session_name_for_dir "$session_dir")
        status_line=$(garth_session_status_line "$session_dir")
        status="${status_line#*$'\t'}"
        printf '  %d) %s  %s  %s\n' "$idx" "$sname" "$sid" "$status"
        idx=$((idx + 1))
      done
      echo "  $idx) New session"
      local session_choice
      read -r -p "[1] > " session_choice
      session_choice="${session_choice:-1}"
      if [[ "$session_choice" =~ ^[0-9]+$ ]] && ((session_choice >= 1 && session_choice <= ${#session_dirs[@]})); then
        session_name=$(garth_session_name_for_dir "${session_dirs[$((session_choice - 1))]}")
      elif [[ "$session_choice" == "$idx" ]]; then
        new_session=true
      else
        garth_die "Invalid session choice: $session_choice" 1
      fi
    fi
  fi

  local -a open_args=(--dir "$dir")
  [[ -n "$resolved_branch" ]] && open_args+=("$resolved_branch")
  [[ -n "$remote_name" ]] && open_args+=(--remote "$remote_name")
  [[ -n "$worktree_path" ]] && open_args+=(--worktree "$worktree_path")
  [[ -n "$session_name" ]] && open_args+=(--session "$session_name")
  [[ "$new_worktree" == "true" ]] && open_args+=(--new-worktree)
  [[ "$new_session" == "true" ]] && open_args+=(--new-session)
  [[ "$no_worktree" == "true" ]] && open_args+=(--no-worktree)
  open_args+=(${forward[@]+"${forward[@]}"})
  cmd_open "${open_args[@]}"
}

cmd_agent() {
  local dir=""
  local agent=""
  local agents_csv=""
  local auth_passthrough_csv=""
  local sandbox=""
  local network=""
  local safety_mode=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sandbox)
        sandbox="$2"
        shift 2
        ;;
      --auth-passthrough)
        auth_passthrough_csv="$2"
        shift 2
        ;;
      --agents)
        agents_csv="$2"
        shift 2
        ;;
      --network)
        network="$2"
        shift 2
        ;;
      --safety)
        safety_mode="$2"
        shift 2
        ;;
      --dry-run)
        GARTH_DRY_RUN=true
        shift
        ;;
      --yes|-y)
        GARTH_YES=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth agent <dir> [name] [--agents <a,b>] [--sandbox docker|none] [--network bridge|none]
       [--safety safe|permissive] [--auth-passthrough <a,b>]

Notes:
  - <dir> may be a non-git directory.
  - In non-git directories, GitHub token minting is skipped.
  - If [name] and --agents are omitted, defaults.agents is used.
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for agent: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
        elif [[ -z "$agent" ]]; then
          agent="$1"
        else
          garth_die "Unexpected argument: $1" 1
        fi
        shift
        ;;
    esac
  done

  [[ -n "$dir" ]] || garth_die "agent requires <dir>" 1

  load_config
  auth_passthrough_csv="${auth_passthrough_csv:-$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV}"
  csv_to_array "$auth_passthrough_csv"
  local normalized_passthrough=()
  local passthrough_agent
  for passthrough_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
    passthrough_agent="${passthrough_agent// /}"
    [[ -n "$passthrough_agent" ]] || continue
    normalized_passthrough+=("$passthrough_agent")
  done
  auth_passthrough_csv=$(garth_join_by "," "${normalized_passthrough[@]:-}")
  sandbox="${sandbox:-$GARTH_DEFAULTS_SANDBOX}"
  network="${network:-$GARTH_DEFAULTS_NETWORK}"
  safety_mode="${safety_mode:-$GARTH_DEFAULTS_SAFETY_MODE}"

  if [[ -n "$agent" && -n "$agents_csv" ]]; then
    garth_die "Use either [name] or --agents, not both." 1
  fi
  local requested_agents_csv=""
  if [[ -n "$agents_csv" ]]; then
    requested_agents_csv="$agents_csv"
  elif [[ -n "$agent" ]]; then
    requested_agents_csv="$agent"
  fi
  resolve_agents "$requested_agents_csv"
  local -a selected_agents=("${GARTH_SELECTED_AGENTS[@]}")
  local selected_agents_csv
  selected_agents_csv=$(garth_join_by "," "${selected_agents[@]}")

  if [[ "$sandbox" == "docker" ]]; then
    local -a auto_passthrough_agents=()
    local selected_agent
    for selected_agent in "${selected_agents[@]}"; do
      if csv_contains_token "$auth_passthrough_csv" "$selected_agent"; then
        continue
      fi
      if garth_agent_has_local_cli_auth "$selected_agent"; then
        normalized_passthrough+=("$selected_agent")
        auto_passthrough_agents+=("$selected_agent")
      fi
    done
    if [[ ${#auto_passthrough_agents[@]} -gt 0 ]]; then
      auth_passthrough_csv=$(garth_join_by "," "${normalized_passthrough[@]:-}")
      garth_log_info "Auto-enabled auth passthrough from local CLI auth: $(garth_join_by "," "${auto_passthrough_agents[@]}")"
    fi
  fi

  if [[ "$sandbox" == "docker" && -n "$auth_passthrough_csv" ]]; then
    garth_log_warn "Docker auth passthrough is enabled for: $auth_passthrough_csv"
    garth_log_warn "This weakens isolation by exposing local CLI auth state to containers."
  fi

  local abs_dir repo_root branch repo_name session
  local is_git_repo=true
  abs_dir=$(garth_abs_path "$dir")
  if repo_root=$(garth_git_repo_root "$abs_dir" 2>/dev/null); then
    branch=$(garth_git_current_branch "$repo_root")
    repo_name=$(garth_git_repo_name "$repo_root")
    session="$(garth_git_session_name "$repo_name" "$branch")-adhoc"
  else
    is_git_repo=false
    repo_root="$abs_dir"
    branch="nogit"
    repo_name=$(garth_slugify_branch "$(basename "$abs_dir")")
    session="garth-${repo_name}-adhoc"
    garth_log_warn "Directory is not a git repository; continuing without GitHub repo metadata."
  fi

  local tmp_dir
  tmp_dir=$(garth_make_temp_dir)

  local token expires_at expires_epoch installation_id owner_repo
  if [[ "$is_git_repo" == "true" ]]; then
    local minted_file
    minted_file=$(mktemp "${TMPDIR:-/tmp}/garth-minted-token.XXXXXX") || return 1
    garth_register_cleanup_path "$minted_file"
    mint_token_for_repo "$repo_root" > "$minted_file" || return 3
    IFS=$'\t' read -r token expires_at expires_epoch installation_id owner_repo < "$minted_file"
  else
    token=""
    expires_at="-"
    expires_epoch="0"
    installation_id="-"
    owner_repo="-"
  fi
  garth_write_token_file "$tmp_dir" "$token" >/dev/null

  local selected_agent
  local require_api_key
  for selected_agent in "${selected_agents[@]}"; do
    require_api_key=true
    if [[ "$sandbox" == "none" ]] || csv_contains_token "$auth_passthrough_csv" "$selected_agent"; then
      require_api_key=false
    fi
    garth_prepare_agent_env_file "$tmp_dir" "$selected_agent" "$require_api_key" >/dev/null || return 3
  done

  if [[ ${#selected_agents[@]} -gt 1 ]]; then
    if [[ "$sandbox" == "docker" && "$GARTH_DRY_RUN" != "true" ]]; then
      garth_require_cmd docker
      for selected_agent in "${selected_agents[@]}"; do
        garth_ensure_agent_image_ready "$selected_agent" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" || \
          garth_die "Docker image setup failed for agent '$selected_agent'" 1
      done
    fi

    local layout_file
    layout_file=$(mktemp "${TMPDIR:-/tmp}/garth-layout.${session}.XXXXXX.kdl") || return 1
    garth_register_cleanup_path "$layout_file"
    garth_generate_zellij_layout "$layout_file" "$abs_dir" "$session" "$repo_root" "$tmp_dir" "$network" \
      "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" "$safety_mode" "$sandbox" "$auth_passthrough_csv" "${selected_agents[@]}"

    if [[ "$GARTH_DRY_RUN" != "true" ]]; then
      garth_log_info "Launching multi-agent adhoc session: $selected_agents_csv"
    fi
    garth_zellij_launch "$session" "$layout_file"
    return 0
  fi

  agent="${selected_agents[0]}"

  if [[ "$sandbox" == "none" ]]; then
    local cmd
    cmd=$(garth_agent_command_string "$agent" "$safety_mode")
    local env_file="$tmp_dir/agent-${agent}.env"
    garth_log_warn "Running without sandbox; agent has host access"
    if [[ "$GARTH_DRY_RUN" == "true" ]]; then
      echo "[dry-run] source $env_file && export GITHUB_TOKEN=... && $cmd"
      return 0
    fi
    local rc=0
    (
      cd "$abs_dir"
      set -a
      # shellcheck disable=SC1090
      source "$env_file"
      set +a
      export GITHUB_TOKEN
      GITHUB_TOKEN=$(cat "$tmp_dir/github_token")
      bash -lc "$cmd"
    ) || rc=$?
    if ((rc != 0)); then
      garth_audit_log "$tmp_dir" "agent_exit_nonzero" \
        "agent=$agent" \
        "repo_root=$repo_root" \
        "worktree=$abs_dir" \
        "sandbox=$sandbox" \
        "network=$network" \
        "safety_mode=$safety_mode" \
        "exit_code=$rc"
      return "$rc"
    fi
    garth_audit_log "$tmp_dir" "agent_exit" \
      "agent=$agent" \
      "repo_root=$repo_root" \
      "worktree=$abs_dir" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode" \
      "exit_code=0"
    return 0
  fi

  garth_require_cmd docker
  if [[ "$GARTH_DRY_RUN" != "true" ]]; then
    garth_ensure_agent_image_ready "$agent" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" || \
      garth_die "Docker image setup failed for agent '$agent'" 1
  fi
  local auth_passthrough_enabled=false
  if csv_contains_token "$auth_passthrough_csv" "$agent"; then
    auth_passthrough_enabled=true
  fi
  local -a args=()
  local arg
  while IFS= read -r arg; do
    args+=("$arg")
  done < <(garth_container_args_lines "$session" "$repo_root" "$abs_dir" "$agent" "$tmp_dir/agent-${agent}.env" "$tmp_dir" "$network" "$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX" "$safety_mode" "$auth_passthrough_enabled")

  if [[ "$GARTH_DRY_RUN" == "true" ]]; then
    echo "docker ${args[*]}"
    return 0
  fi

  local docker_rc=0
  docker "${args[@]}" || docker_rc=$?
  if ((docker_rc != 0)); then
    garth_audit_log "$tmp_dir" "agent_exit_nonzero" \
      "agent=$agent" \
      "repo_root=$repo_root" \
      "worktree=$abs_dir" \
      "sandbox=$sandbox" \
      "network=$network" \
      "safety_mode=$safety_mode" \
      "exit_code=$docker_rc"
    return "$docker_rc"
  fi
  garth_audit_log "$tmp_dir" "agent_exit" \
    "agent=$agent" \
    "repo_root=$repo_root" \
    "worktree=$abs_dir" \
    "sandbox=$sandbox" \
    "network=$network" \
    "safety_mode=$safety_mode" \
    "exit_code=0"
}

cmd_token() {
  local dir=""
  local machine=false
  local write_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --machine)
        machine=true
        shift
        ;;
      --write-file)
        write_file="$2"
        shift 2
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth token <dir> [--machine] [--write-file <path>]
HELP
        return 0
        ;;
      -* )
        garth_die "Unknown option for token: $1" 1
        ;;
      *)
        if [[ -z "$dir" ]]; then
          dir="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done

  [[ -n "$dir" ]] || garth_die "token requires <dir>" 1

  load_config

  local abs_dir repo_root token expires_at expires_epoch installation_id owner_repo
  abs_dir=$(garth_abs_path "$dir")
  repo_root=$(garth_git_repo_root "$abs_dir") || garth_die "Not inside a git repo: $abs_dir" 1
  local minted_file
  minted_file=$(mktemp "${TMPDIR:-/tmp}/garth-minted-token.XXXXXX") || return 1
  garth_register_cleanup_path "$minted_file"
  mint_token_for_repo "$repo_root" > "$minted_file" || return 3
  IFS=$'\t' read -r token expires_at expires_epoch installation_id owner_repo < "$minted_file"

  if [[ -n "$write_file" ]]; then
    mkdir -p "$(dirname "$write_file")"
    umask 077
    printf '%s\n' "$token" > "$write_file"
    chmod 600 "$write_file"
  fi

  if [[ "$machine" == "true" ]]; then
    printf '%s\t%s\t%s\t%s\t%s\n' "$token" "$expires_at" "$expires_epoch" "$installation_id" "$owner_repo"
  else
    printf '%s\n' "$token"
  fi
}

human_uptime() {
  local seconds="$1"
  if ((seconds < 60)); then
    echo "${seconds}s"
  elif ((seconds < 3600)); then
    echo "$((seconds / 60))m"
  else
    echo "$((seconds / 3600))h"
  fi
}

garth_docker_image_state() {
  local image_tag="$1"
  local err_file
  err_file=$(mktemp "${TMPDIR:-/tmp}/garth-docker-inspect.XXXXXX") || {
    echo "unavailable:failed to create temp file"
    return 0
  }
  garth_register_cleanup_path "$err_file"

  if docker image inspect "$image_tag" >/dev/null 2>"$err_file"; then
    rm -f "$err_file"
    echo "present"
    return 0
  fi

  local err_msg
  err_msg=$(tr '\n' ' ' < "$err_file" | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')
  rm -f "$err_file"

  if [[ "$err_msg" =~ [Nn]o\ such\ image ]] || [[ "$err_msg" =~ [Nn]ot\ found ]]; then
    echo "missing"
    return 0
  fi

  echo "unavailable:${err_msg:-docker inspect failed}"
}

count_session_containers() {
  local session="$1"
  if ! command -v docker >/dev/null 2>&1; then
    echo "0"
    return 0
  fi
  docker ps -q --filter "label=garth.session=$session" | wc -l | tr -d ' '
}

count_session_containers_all() {
  local session="$1"
  if ! command -v docker >/dev/null 2>&1; then
    echo "0"
    return 0
  fi
  docker ps -aq --filter "label=garth.session=$session" | wc -l | tr -d ' '
}

garth_zellij_attachment_state() {
  local session="$1"
  local line
  while IFS= read -r line; do
    [[ "${line%% *}" == "$session" ]] || continue
    if [[ "$line" =~ ([1-9][0-9]*)[[:space:]]+clients ]]; then
      echo "attached"
      return 0
    fi
    if [[ "$line" =~ [[:space:]]0[[:space:]]+clients ]] || [[ "$line" == *"no clients"* ]]; then
      echo "detached"
      return 0
    fi
    echo "unknown"
    return 0
  done < <(zellij list-sessions -n 2>/dev/null || true)
  echo "unknown"
}

garth_sort_session_dirs_by_started() {
  local dir started
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    started=$(read_state_value "$dir" "started_epoch")
    if [[ ! "$started" =~ ^[0-9]+$ ]]; then
      started=0
    fi
    printf '%s\t%s\n' "$started" "$dir"
  done | sort -nr -k1,1 | cut -f2-
}

garth_session_status_line() {
  local session_dir="$1"
  local session id token_state
  session=$(garth_session_name_for_dir "$session_dir")
  id=$(garth_session_id_for_dir "$session_dir")
  token_state=$(read_state_value "$session_dir" "token_state")

  local zellij_state attach_state active containers_running containers_all
  zellij_state=$(garth_zellij_session_state "$session")
  attach_state=$(garth_zellij_attachment_state "$session")
  active="false"
  [[ -f "$session_dir/active" ]] && active="true"
  containers_running=$(count_session_containers "$session")
  containers_all=$(count_session_containers_all "$session")

  local status="" reason=""
  if [[ "$token_state" == "degraded" ]]; then
    status="degraded"
    reason="token refresh degraded"
  elif [[ "$zellij_state" != "running" && "$containers_running" -gt 0 ]]; then
    status="degraded"
    reason="zellij gone, containers alive"
  elif [[ "$zellij_state" == "running" && "$containers_running" -eq 0 && "$active" == "true" ]]; then
    status="degraded"
    reason="container exited"
  elif [[ -f "$session_dir/stopped_epoch" && ( "$zellij_state" == "running" || "$containers_running" -gt 0 || "$containers_all" -gt 0 ) ]]; then
    status="degraded"
    reason="stop incomplete"
  elif [[ "$zellij_state" == "running" ]]; then
    if [[ "$attach_state" == "detached" ]]; then
      status="detached"
    elif [[ "$attach_state" == "attached" ]]; then
      status="running"
    else
      status="running(?)"
    fi
  elif [[ -f "$session_dir/stopped_epoch" || "$active" != "true" ]]; then
    status="stopped"
  else
    status="degraded"
    reason="state mismatch"
  fi

  if [[ "$status" == "degraded" && -n "$reason" ]]; then
    printf '%s\t%s (%s)\n' "$id" "$status" "$reason"
  else
    printf '%s\t%s\n' "$id" "$status"
  fi
}

garth_find_session_dir_by_id_prefix() {
  local prefix="$1"
  local -a matches=()
  local dir
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    matches+=("$dir")
  done < <(garth_find_sessions_by_id_prefix "$prefix")

  if [[ ${#matches[@]} -eq 0 ]]; then
    garth_die "No session matches ID prefix '$prefix'" 5
  fi

  if [[ ${#matches[@]} -gt 1 ]]; then
    echo "Multiple sessions match prefix '$prefix'. Be more specific." >&2
    local m
    for m in "${matches[@]}"; do
      echo "  $(garth_session_id_for_dir "$m")  $(garth_session_name_for_dir "$m")" >&2
    done
    exit 5
  fi

  printf '%s\n' "${matches[0]}"
}

stop_session() {
  local session="$1"
  local session_dir
  session_dir=$(session_dir_for "$session")
  [[ -d "$session_dir" ]] || return 0

  local repo_root worktree branch agents_csv
  repo_root=$(read_state_value "$session_dir" "repo_root")
  worktree=$(read_state_value "$session_dir" "worktree")
  branch=$(read_state_value "$session_dir" "branch")
  agents_csv=$(read_state_value "$session_dir" "agents_csv")
  garth_audit_log "$session_dir" "session_stop_requested" \
    "session=$session" \
    "repo_root=$repo_root" \
    "worktree=$worktree" \
    "branch=$branch" \
    "agents=$agents_csv"

  rm -f "$session_dir/active" 2>/dev/null || true
  write_state_value "$session_dir" "stopped_epoch" "$(garth_now_epoch)"

  local pid
  pid=$(read_state_value "$session_dir" "refresher_pid")
  if [[ -n "$pid" ]]; then
    kill "$pid" >/dev/null 2>&1 || true
    garth_audit_log "$session_dir" "token_refresher_stopped" \
      "session=$session" \
      "refresher_pid=$pid"
  fi

  if command -v docker >/dev/null 2>&1; then
    garth_stop_containers_for_session "$session"
    garth_audit_log "$session_dir" "container_stop" \
      "session=$session"
  fi

  garth_zellij_kill_session "$session"
  garth_audit_log "$session_dir" "zellij_stop" \
    "session=$session"
  garth_post_session_report "$session" "$session_dir" "$worktree"
  garth_audit_log "$session_dir" "session_stop_complete" \
    "session=$session"
}

stop_session_by_dir() {
  local session_dir="$1"
  local session
  session=$(garth_session_name_for_dir "$session_dir")
  stop_session "$session"
}

cmd_ps() {
  local quiet=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -q|--quiet)
        quiet=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth ps [-q]

List all garth sessions with their status.

Options:
  -q, --quiet     Output only session IDs, one per line (no header).
                  Useful for piping: garth ps -q | xargs garth stop

Output columns:
  ID              Short random session identifier (use with stop, down, containers)
  SESSION         Full session name
  REPO            Repository name
  BRANCH          Git branch
  WORKTREE        Worktree directory (- if none)
  AGENTS          Comma-separated agent list
  STATUS          running, running(?), detached, stopped, or degraded (reason)
  UPTIME          Time since session was started
HELP
        return 0
        ;;
      *)
        garth_die "Unknown option for ps: $1" 1
        ;;
    esac
  done

  ensure_state_root

  local -a dirs=()
  local dir
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    dirs+=("$dir")
  done < <(garth_session_list_dirs)

  if [[ ${#dirs[@]} -eq 0 ]]; then
    return 0
  fi

  if [[ "$quiet" == "true" ]]; then
    for dir in "${dirs[@]}"; do
      garth_session_id_for_dir "$dir"
    done
    return 0
  fi

  printf '%-8s %-36s %-22s %-16s %-20s %-16s %-28s %-8s\n' \
    "ID" "SESSION" "REPO" "BRANCH" "WORKTREE" "AGENTS" "STATUS" "UPTIME"

  for dir in "${dirs[@]}"; do
    local id session repo_root owner_repo repo branch worktree worktree_short agents_csv status_line status now started uptime
    id=$(garth_session_id_for_dir "$dir")
    session=$(garth_session_name_for_dir "$dir")
    repo_root=$(read_state_value "$dir" "repo_root")
    owner_repo=$(read_state_value "$dir" "owner_repo")
    if [[ -n "$owner_repo" && "$owner_repo" == */* ]]; then
      repo="${owner_repo##*/}"
    else
      repo=$(garth_git_repo_name "$repo_root")
    fi
    branch=$(read_state_value "$dir" "branch")
    worktree=$(read_state_value "$dir" "worktree")
    worktree_short="-"
    [[ -n "$worktree" ]] && worktree_short=$(basename "$worktree")
    agents_csv=$(read_state_value "$dir" "agents_csv")
    status_line=$(garth_session_status_line "$dir")
    status="${status_line#*$'\t'}"
    now=$(garth_now_epoch)
    started=$(read_state_value "$dir" "started_epoch")
    if [[ ! "$started" =~ ^[0-9]+$ ]]; then
      started="$now"
    fi
    uptime=$(human_uptime $((now - started)))
    printf '%-8s %-36s %-22s %-16s %-20s %-16s %-28s %-8s\n' \
      "$id" "$session" "$repo" "$branch" "$worktree_short" "$agents_csv" "$status" "$uptime"
  done
}

cmd_containers() {
  local id_prefix="${1:-}"
  if [[ "$id_prefix" == "--help" || "$id_prefix" == "-h" ]]; then
    cat << 'HELP'
Usage: garth containers <id>

List Docker container IDs for a session. Output is one container ID per line,
suitable for piping into docker commands.

Arguments:
  <id>            Session ID or unambiguous prefix (from garth ps)

Examples:
  garth containers a1b2c3                     List container IDs
  garth containers a1b | xargs docker logs    View logs for all containers
  garth containers a1b | xargs docker stats   Monitor resource usage
HELP
    return 0
  fi
  [[ -n "$id_prefix" ]] || garth_die "containers requires <id>" 1
  ensure_state_root
  local session_dir session
  session_dir=$(garth_find_session_dir_by_id_prefix "$id_prefix")
  session=$(garth_session_name_for_dir "$session_dir")
  garth_list_containers_for_session "$session"
}

cmd_stop() {
  local id_prefix=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat << 'HELP'
Usage: garth stop <id>

Stop a session's Zellij session and Docker containers. The worktree, branch,
and session state are preserved so the session can be resumed later with
'garth open' or removed entirely with 'garth down'.

Arguments:
  <id>            Session ID or unambiguous prefix (from garth ps)

Examples:
  garth stop a1b2c3                 Stop a specific session
  garth ps -q | xargs garth stop   Stop all sessions
HELP
        return 0
        ;;
      -*)
        garth_die "Unknown option for stop: $1" 1
        ;;
      *)
        if [[ -z "$id_prefix" ]]; then
          id_prefix="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done
  [[ -n "$id_prefix" ]] || garth_die "stop requires <id>" 1
  ensure_state_root
  local session_dir session
  session_dir=$(garth_find_session_dir_by_id_prefix "$id_prefix")
  session=$(garth_session_name_for_dir "$session_dir")
  garth_log_info "Stopping session: $session ($(garth_session_id_for_dir "$session_dir"))"
  stop_session_by_dir "$session_dir"
}

worktree_has_uncommitted_changes() {
  local worktree="$1"
  [[ -d "$worktree" ]] || return 1
  [[ -n "$(git -C "$worktree" status --porcelain 2>/dev/null || true)" ]]
}

worktree_has_unpushed_changes() {
  local worktree="$1"
  [[ -d "$worktree" ]] || return 1
  if git -C "$worktree" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    [[ -n "$(git -C "$worktree" log --oneline '@{u}..' 2>/dev/null || true)" ]]
  else
    return 1
  fi
}

cmd_down() {
  local id_prefix=""
  local yes=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -y|--yes)
        yes=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth down <id> [-y]

Remove a session and all its resources: Zellij session, Docker containers,
session state directory, and managed worktree. Warns before deleting a
worktree that has uncommitted or unpushed changes.

Arguments:
  <id>            Session ID or unambiguous prefix (from garth ps)

Options:
  -y, --yes       Skip confirmation prompt

Examples:
  garth down a1b2c3                 Remove a session (with confirmation)
  garth down a1b2c3 -y              Remove without confirmation
  garth ps -q | xargs -I{} garth down {} -y
                                    Remove all sessions
HELP
        return 0
        ;;
      -*)
        garth_die "Unknown option for down: $1" 1
        ;;
      *)
        if [[ -z "$id_prefix" ]]; then
          id_prefix="$1"
          shift
        else
          garth_die "Unexpected argument: $1" 1
        fi
        ;;
    esac
  done

  [[ -n "$id_prefix" ]] || garth_die "down requires <id>" 1
  ensure_state_root
  local session_dir session worktree managed repo_root
  session_dir=$(garth_find_session_dir_by_id_prefix "$id_prefix")
  session=$(garth_session_name_for_dir "$session_dir")
  worktree=$(read_state_value "$session_dir" "worktree")
  managed=$(read_state_value "$session_dir" "worktree_managed")
  repo_root=$(read_state_value "$session_dir" "repo_root")
  local container_count
  container_count=$(garth_list_containers_for_session "$session" | sed '/^$/d' | wc -l | tr -d ' ')

  garth_log_info "Delete plan for session $(garth_session_id_for_dir "$session_dir"):"
  echo "  - session state: $session_dir"
  echo "  - zellij session: $session"
  echo "  - containers: $container_count"
  if [[ "$managed" == "true" && -n "$worktree" ]]; then
    echo "  - managed worktree: $worktree"
  else
    echo "  - managed worktree: none"
  fi

  if [[ "$yes" != "true" && "$managed" == "true" ]]; then
    if worktree_has_uncommitted_changes "$worktree" || worktree_has_unpushed_changes "$worktree"; then
      garth_log_warn "Worktree has uncommitted or unpushed changes: $worktree"
    fi
  fi

  if [[ "$yes" != "true" ]]; then
    if ! garth_ask_yn "Proceed with deletion?"; then
      garth_log_info "Aborted"
      return 0
    fi
  fi

  garth_log_info "Deleting session: $session ($(garth_session_id_for_dir "$session_dir"))"
  stop_session_by_dir "$session_dir"

  if [[ "$managed" == "true" && -n "$worktree" && -d "$worktree" ]]; then
    if [[ -n "$repo_root" ]] && git -C "$repo_root" worktree list --porcelain 2>/dev/null | grep -Fq "worktree $worktree"; then
      git -C "$repo_root" worktree remove --force "$worktree" >/dev/null 2>&1 || true
    fi
    rm -rf "$worktree"
  fi
  rm -rf "$session_dir"
}

garth_sed_escape_replacement() {
  printf '%s' "$1" | sed -e 's/[&|\\]/\\&/g'
}

garth_set_config_string_value() {
  local key="$1"
  local value="$2"
  local escaped
  escaped=$(garth_sed_escape_replacement "$value")
  sed -i.bak "s|^${key} = \".*\"|${key} = \"${escaped}\"|" "$GARTH_CONFIG_PATH"
  rm -f "$GARTH_CONFIG_PATH.bak"
}

garth_first_vault_name() {
  local json
  json="$(op vault list --format json 2>/dev/null)" || return 1
  garth_python - << 'PY' "$json"
import json
import sys
try:
    data = json.loads(sys.argv[1])
except Exception:
    raise SystemExit(1)
if isinstance(data, list) and data:
    first = data[0]
    if isinstance(first, dict):
        print(first.get("name", ""))
PY
}

garth_list_vault_names() {
  local json
  json="$(op vault list --format json 2>/dev/null)" || return 0
  garth_python - << 'PY' "$json"
import json
import sys
try:
    data = json.loads(sys.argv[1])
except Exception:
    raise SystemExit(0)
if not isinstance(data, list):
    raise SystemExit(0)
for item in data:
    if isinstance(item, dict):
        name = item.get("name")
        if isinstance(name, str) and name:
            print(f"  - {name}")
PY
}

garth_validate_ref_readable() {
  local ref="$1"
  op read "$ref" >/dev/null 2>&1
}

garth_ref_looks_configured() {
  local ref="$1"
  [[ -n "$ref" ]] || return 1
  [[ "$ref" == op://* ]] || return 1
  [[ "$ref" != *"<"* ]]
}

garth_github_app_refs_look_configured() {
  garth_ref_looks_configured "${GARTH_GITHUB_APP_APP_ID_REF:-}" || return 1
  garth_ref_looks_configured "${GARTH_GITHUB_APP_PRIVATE_KEY_REF:-}" || return 1

  case "${GARTH_GITHUB_APP_INSTALLATION_STRATEGY:-by_owner}" in
    single)
      garth_ref_looks_configured "${GARTH_GITHUB_APP_INSTALLATION_ID_REF:-}" || return 1
      ;;
    static_map|by_owner)
      :
      ;;
    *)
      return 1
      ;;
  esac

  return 0
}

garth_prompt_op_signin() {
  if [[ "$GARTH_YES" == "true" ]]; then
    garth_log_info "1Password CLI is not signed in; attempting automatic 'op signin'"
    if ! eval "$(op signin)"; then
      garth_log_warn "Automatic op signin failed; skipping GitHub App ref setup"
      garth_log_info "Run: eval \"\$(op signin)\" and then rerun 'garth setup'"
      return 1
    fi

    if ! op whoami >/dev/null 2>&1; then
      garth_log_warn "Automatic op signin did not establish a CLI session; skipping GitHub App ref setup"
      return 1
    fi

    garth_log_success "1Password CLI sign-in complete"
    return 0
  fi

  garth_log_warn "1Password CLI is not signed in"
  if ! garth_ask_yn "Run 'op signin' now?"; then
    garth_log_warn "Skipping GitHub App ref setup: op CLI is not signed in"
    garth_log_info "Run: eval \"\$(op signin)\" and then rerun 'garth setup'"
    return 1
  fi

  if ! eval "$(op signin)"; then
    garth_log_warn "op signin failed; skipping GitHub App ref setup"
    garth_log_info "Run: eval \"\$(op signin)\" and then rerun 'garth setup'"
    return 1
  fi

  if ! op whoami >/dev/null 2>&1; then
    garth_log_warn "op signin did not establish a CLI session; skipping GitHub App ref setup"
    return 1
  fi

  garth_log_success "1Password CLI sign-in complete"
  return 0
}

garth_configure_github_app_refs() {
  # Skip guided ref setup when config already contains non-placeholder op:// refs.
  load_config
  if garth_github_app_refs_look_configured; then
    garth_log_info "GitHub App refs already configured in $GARTH_CONFIG_PATH; skipping guided setup"
    return 0
  fi

  if ! command -v op >/dev/null 2>&1; then
    garth_log_warn "Skipping GitHub App ref setup: op CLI not installed"
    return 0
  fi

  if ! op whoami >/dev/null 2>&1; then
    garth_prompt_op_signin || return 0
  fi

  if [[ "$GARTH_YES" == "true" ]]; then
    garth_log_info "Non-interactive setup: skipped guided GitHub App ref prompts"
    garth_log_info "Edit $GARTH_CONFIG_PATH [github_app] refs to match your 1Password vault/item"
    return 0
  fi

  if ! garth_ask_yn "Configure GitHub App 1Password refs now?"; then
    return 0
  fi

  garth_log_info "Available vaults:"
  garth_list_vault_names || true

  local default_vault
  default_vault=$(garth_first_vault_name || true)
  [[ -n "$default_vault" ]] || default_vault="Private"

  local vault item app_field private_key_field installation_field
  vault=$(garth_prompt_with_default "Vault name" "$default_vault")
  item=$(garth_prompt_with_default "Item name" "GitHub App")
  app_field=$(garth_prompt_with_default "App ID field label or id" "app-id")
  private_key_field=$(garth_prompt_with_default "Private key field label or id" "private-key")
  installation_field=$(garth_prompt_with_default "Installation ID field label or id" "installation-id")

  local app_ref private_ref installation_ref
  app_ref="op://${vault}/${item}/${app_field}"
  private_ref="op://${vault}/${item}/${private_key_field}"
  installation_ref="op://${vault}/${item}/${installation_field}"

  garth_set_config_string_value "app_id_ref" "$app_ref"
  garth_set_config_string_value "private_key_ref" "$private_ref"
  garth_set_config_string_value "installation_id_ref" "$installation_ref"

  local ok=true
  if ! garth_validate_ref_readable "$app_ref"; then
    garth_log_warn "Cannot read app_id_ref: $app_ref"
    ok=false
  fi
  if ! garth_validate_ref_readable "$private_ref"; then
    garth_log_warn "Cannot read private_key_ref: $private_ref"
    ok=false
  fi
  if ! garth_validate_ref_readable "$installation_ref"; then
    garth_log_warn "Cannot read installation_id_ref: $installation_ref"
    ok=false
  fi

  if [[ "$ok" == "true" ]]; then
    garth_log_success "Updated and validated [github_app] refs"
  else
    garth_log_warn "Saved refs but validation failed. Check vault/item/field names in $GARTH_CONFIG_PATH"
  fi
}

garth_setup_aerospace() {
  local non_interactive="$1"

  if ! garth_is_macos; then
    return 0
  fi

  if command -v aerospace >/dev/null 2>&1; then
    garth_log_success "aerospace is installed"
    return 0
  fi

  garth_log_warn "aerospace is not installed; workspace auto-placement needs it"
  if ! command -v brew >/dev/null 2>&1; then
    garth_log_warn "Homebrew not found. Install AeroSpace manually from https://github.com/nikitabobko/AeroSpace"
    return 0
  fi

  if [[ "$non_interactive" == "true" ]] || garth_ask_yn "Install AeroSpace via Homebrew now?"; then
    garth_log_info "Installing AeroSpace via Homebrew"
    if brew tap nikitabobko/tap && brew install --cask aerospace; then
      garth_log_success "Installed aerospace"
    else
      garth_log_warn "AeroSpace install failed. Run manually:"
      garth_log_warn "  brew tap nikitabobko/tap && brew install --cask aerospace"
    fi
  else
    garth_log_warn "Skipping AeroSpace install. Workspace auto-placement will be disabled."
  fi
}

garth_setup_python3() {
  local non_interactive="${1:-false}"

  if ! garth_is_macos; then
    return 0
  fi

  local py_path py_ver
  py_path="$(command -v "$GARTH_PYTHON_BIN" || true)"
  py_ver="$("$GARTH_PYTHON_BIN" --version 2>/dev/null || true)"

  if [[ "$py_path" != "/usr/bin/python3" ]]; then
    return 0
  fi

  garth_log_warn "Detected macOS system python3 ($py_ver at $py_path)"
  garth_log_warn "This can trigger Command Line Tools prompts during setup/use."

  if [[ -x "/opt/homebrew/bin/python3" ]]; then
    garth_log_info "Homebrew python3 already installed at /opt/homebrew/bin/python3"
    garth_log_warn "Ensure /opt/homebrew/bin appears before /usr/bin in your PATH."
    return 0
  fi

  if ! command -v brew >/dev/null 2>&1; then
    garth_log_warn "Homebrew not found. Install Homebrew, then run: brew install python"
    return 0
  fi

  if [[ "$non_interactive" == "true" ]] || garth_ask_yn "Install Homebrew python now?"; then
    garth_log_info "Installing Homebrew python"
    if brew install python; then
      garth_log_success "Installed Homebrew python"
      garth_log_warn "Add to shell init if needed:"
      garth_log_warn "  export PATH=\"/opt/homebrew/bin:\$PATH\""
    else
      garth_log_warn "Homebrew python install failed. Run manually: brew install python"
    fi
  else
    garth_log_warn "Skipping Homebrew python install."
  fi
}

garth_shell_single_quote() {
  local raw="$1"
  printf "'%s'" "$(printf '%s' "$raw" | sed "s/'/'\"'\"'/g")"
}

garth_write_image_refresh_script() {
  local script_path="$1"
  local image_prefix="$2"
  local agents_csv="$3"
  local features_packages_csv="$4"

  local script_dir
  script_dir=$(dirname "$script_path")
  mkdir -p "$script_dir"
  chmod 700 "$script_dir"

  csv_to_array "$agents_csv"
  local -a configured_agents=("${_GARTH_ARRAY_OUT[@]:-}")
  local -a agents=()
  local agent
  for agent in "${configured_agents[@]}"; do
    agent="${agent// /}"
    [[ -n "$agent" ]] || continue
    agents+=("$agent")
  done
  if [[ ${#agents[@]} -eq 0 ]]; then
    agents=(claude codex)
  fi

  {
    echo "#!/usr/bin/env bash"
    echo "set -euo pipefail"
    printf 'DOCKER_DIR=%q\n' "$GARTH_ROOT/docker"
    printf 'IMAGE_PREFIX=%q\n' "$image_prefix"
    printf 'FEATURE_PACKAGES_CSV=%q\n' "$features_packages_csv"
    echo "if ! command -v docker >/dev/null 2>&1; then"
    echo "  echo \"docker not found; skipping Garth image refresh\" >&2"
    echo "  exit 0"
    echo "fi"
    echo "agents=("
    for agent in "${agents[@]}"; do
      printf '  %q\n' "$agent"
    done
    echo ")"
    echo "for agent in \"\${agents[@]}\"; do"
    echo "  docker build --pull --no-cache --build-arg \"GARTH_FEATURE_PACKAGES=\${FEATURE_PACKAGES_CSV}\" --target \"\$agent\" -t \"\${IMAGE_PREFIX}-\${agent}:latest\" \"\$DOCKER_DIR\""
    echo "done"
  } > "$script_path"
  chmod 700 "$script_path"
}

garth_setup_image_refresh_cron() {
  local image_prefix="$1"
  local agents_csv="$2"
  local features_packages_csv="$3"

  if ! command -v crontab >/dev/null 2>&1; then
    garth_log_warn "Skipping cron setup: 'crontab' command not found"
    return 0
  fi

  if ! garth_ask_yn "Install a weekly cron job to refresh Garth Docker images?"; then
    garth_log_info "Skipped cron image refresh setup"
    return 0
  fi

  ensure_state_root
  local cron_dir="$GARTH_STATE_ROOT/cron"
  local script_path="$cron_dir/refresh-images.sh"
  local log_path="$cron_dir/refresh-images.log"
  local schedule="${GARTH_IMAGE_REFRESH_CRON_SCHEDULE:-15 3 * * 0}"
  local repo_key
  repo_key=$(echo "$GARTH_ROOT" | sed -E 's/[^A-Za-z0-9._-]+/_/g')
  local marker="# garth-image-refresh:${repo_key}"

  garth_write_image_refresh_script "$script_path" "$image_prefix" "$agents_csv" "$features_packages_csv"

  local existing
  existing=$(crontab -l 2>/dev/null || true)

  local had_entry=false
  if [[ -n "$existing" ]] && printf '%s\n' "$existing" | grep -Fq "$marker"; then
    had_entry=true
  fi

  local filtered=""
  if [[ -n "$existing" ]]; then
    filtered=$(printf '%s\n' "$existing" | grep -Fv "$marker" || true)
  fi

  local script_q log_q cron_line new_crontab
  script_q=$(garth_shell_single_quote "$script_path")
  log_q=$(garth_shell_single_quote "$log_path")
  cron_line="${schedule} ${script_q} >> ${log_q} 2>&1 ${marker}"

  if [[ -n "$filtered" ]]; then
    new_crontab="${filtered}"$'\n'"${cron_line}"$'\n'
  else
    new_crontab="${cron_line}"$'\n'
  fi

  if printf '%s' "$new_crontab" | crontab -; then
    if [[ "$had_entry" == "true" ]]; then
      garth_log_success "Updated cron image refresh job (${schedule})"
    else
      garth_log_success "Installed cron image refresh job (${schedule})"
    fi
    garth_log_info "Refresh script: $script_path"
    garth_log_info "Refresh log: $log_path"
  else
    garth_log_warn "Failed to install cron image refresh job"
  fi
}

cmd_refresh_images() {
  local agents_csv=""
  local image_prefix=""
  local dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agents)
        agents_csv="$2"
        shift 2
        ;;
      --image-prefix)
        image_prefix="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth refresh-images [options]

Rebuild Docker images for one or more agents using --pull --no-cache.

Options:
  --agents <a,b>          Comma-separated agents (default: defaults.agents)
  --image-prefix <prefix> Docker image prefix (default: defaults.docker_image_prefix)
  --dry-run               Print build commands without executing

Examples:
  garth refresh-images
  garth refresh-images --agents claude,codex
  garth refresh-images --agents codex --image-prefix garth-dev
HELP
        return 0
        ;;
      *)
        garth_die "Unknown option for refresh-images: $1" 1
        ;;
    esac
  done

  load_config
  resolve_agents "$agents_csv"

  image_prefix="${image_prefix:-$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX}"
  if [[ "$dry_run" == "true" ]]; then
    GARTH_DRY_RUN=true
  else
    garth_require_cmd docker
  fi

  local refreshed=0
  local failed=0
  local agent
  for agent in "${GARTH_SELECTED_AGENTS[@]}"; do
    agent="${agent// /}"
    [[ -n "$agent" ]] || continue
    garth_log_info "Refreshing Docker image: ${image_prefix}-${agent}:latest"
    if garth_docker_refresh_agent_image "$agent" "$image_prefix"; then
      garth_log_success "Refreshed Docker image: ${image_prefix}-${agent}:latest"
      refreshed=$((refreshed + 1))
    else
      garth_log_error "Failed to refresh Docker image: ${image_prefix}-${agent}:latest"
      failed=$((failed + 1))
    fi
  done

  if ((failed > 0)); then
    garth_die "Docker image refresh failed for ${failed} agent(s)" 1
  fi

  garth_log_success "Refreshed ${refreshed} Docker image(s)"
}

cmd_setup() {
  local non_interactive=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y)
        GARTH_YES=true
        non_interactive=true
        shift
        ;;
      --help|-h)
        echo "Usage: garth setup [--yes]"
        return 0
        ;;
      *)
        garth_die "Unknown option for setup: $1" 1
        ;;
    esac
  done

  garth_log_info "Checking prerequisites"
  garth_require_cmd git
  if [[ "$GARTH_PYTHON_BIN" == */* ]]; then
    [[ -x "$GARTH_PYTHON_BIN" ]] || garth_die "Missing required command: $GARTH_PYTHON_BIN" 2
  else
    garth_require_cmd "$GARTH_PYTHON_BIN"
  fi
  garth_setup_python3 "$non_interactive"

  local optional=(docker zellij op)
  local cmd
  for cmd in "${optional[@]}"; do
    if command -v "$cmd" >/dev/null 2>&1; then
      garth_log_success "$cmd is installed"
    else
      garth_log_warn "$cmd is not installed"
    fi
  done

  garth_setup_aerospace "$non_interactive"

  local config_dir
  config_dir=$(dirname "$GARTH_CONFIG_PATH")
  mkdir -p "$config_dir"

  if [[ ! -f "$GARTH_CONFIG_PATH" ]]; then
    local template_path="$GARTH_ROOT/config.example.toml"
    [[ -f "$template_path" ]] || \
      garth_die "Config template not found: $template_path" 1
    cp "$template_path" "$GARTH_CONFIG_PATH"
    garth_log_success "Created config: $GARTH_CONFIG_PATH"

    if garth_ask_yn "Use permissive safety mode by default?"; then
      sed -i.bak 's/^safety_mode = "safe"/safety_mode = "permissive"/' "$GARTH_CONFIG_PATH"
      rm -f "$GARTH_CONFIG_PATH.bak"
      garth_log_warn "Set defaults.safety_mode=permissive"
    fi
  else
    garth_log_info "Config already exists: $GARTH_CONFIG_PATH"
  fi

  garth_configure_github_app_refs

  if garth_python "$GARTH_ROOT/lib/config-parser.py" validate "$GARTH_CONFIG_PATH"; then
    garth_log_success "Config validation passed"
  else
    garth_die "Config validation failed" 1
  fi

  local local_bin="$HOME/.local/bin"
  mkdir -p "$local_bin"
  ln -sf "$GARTH_BIN_PATH" "$local_bin/garth"
  garth_log_success "Installed symlink: $local_bin/garth"

  if [[ -f "$GARTH_ROOT/docker/Dockerfile" ]]; then
    if ! command -v docker >/dev/null 2>&1; then
      garth_log_warn "Skipping Docker image build: docker is not installed"
    else
      load_config
      local image_prefix="$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX"
      local -a missing_agents=()
      local agent image_tag state docker_issue=""
      for agent in claude codex; do
        image_tag="${image_prefix}-${agent}:latest"
        state=$(garth_docker_image_state "$image_tag")
        case "$state" in
          present) ;;
          missing) missing_agents+=("$agent") ;;
          unavailable:*)
            docker_issue="${state#unavailable:}"
            break
            ;;
        esac
      done

      if [[ -n "$docker_issue" ]]; then
        garth_log_warn "Could not query Docker image state: $docker_issue"
        garth_log_warn "Skipping automatic Docker image build. Check Docker daemon/context."
      elif [[ ${#missing_agents[@]} -eq 0 ]]; then
        garth_log_info "Default Docker images exist; validating agent CLIs"
        for agent in claude codex; do
          if garth_ensure_agent_image_ready "$agent" "$image_prefix"; then
            garth_log_success "Docker image ready: ${image_prefix}-${agent}:latest"
          else
            garth_log_warn "Docker image validation failed: ${image_prefix}-${agent}:latest"
          fi
        done
      else
        local missing_csv
        missing_csv=$(IFS=','; echo "${missing_agents[*]}")
        garth_log_info "Building missing default Docker image(s): ${missing_csv}"
        for agent in "${missing_agents[@]}"; do
          if garth_ensure_agent_image_ready "$agent" "$image_prefix"; then
            garth_log_success "Docker image ready: ${image_prefix}-${agent}:latest"
          else
            garth_log_warn "Docker image build/validation failed: ${image_prefix}-${agent}:latest"
          fi
        done
      fi

      local features_packages_csv
      features_packages_csv="$(garth_features_packages_csv)"
      garth_setup_image_refresh_cron "$image_prefix" "$GARTH_DEFAULTS_AGENTS_CSV" "$features_packages_csv"
    fi
  fi

  garth_log_info "Credential checklist:"
  garth_log_info "  1) Ensure [github_app] refs in $GARTH_CONFIG_PATH point to real vault/item fields"
  garth_log_info "  2) Set API key refs under [agents.*] (Anthropic/OpenAI/Google as needed)"
  garth_log_info "  3) Test with: garth token ."

  garth_log_success "Setup complete"
}

cmd_internal_refresh() {
  local repo_root=""
  local session=""
  local session_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-root)
        repo_root="$2"
        shift 2
        ;;
      --session)
        session="$2"
        shift 2
        ;;
      --session-dir)
        session_dir="$2"
        shift 2
        ;;
      *)
        garth_die "Unknown option for internal-refresh: $1" 1
        ;;
    esac
  done

  [[ -n "$repo_root" && -n "$session" && -n "$session_dir" ]] || garth_die "internal-refresh requires --repo-root --session --session-dir" 1

  load_config

  local lead_seconds retry_window_seconds initial_interval_seconds max_interval_seconds
  lead_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_LEAD_TIME")
  retry_window_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_FAILURE_RETRY_WINDOW")
  initial_interval_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_RETRY_INITIAL_INTERVAL")
  max_interval_seconds=$(garth_parse_duration_to_seconds "$GARTH_TOKEN_REFRESH_RETRY_MAX_INTERVAL")
  garth_audit_log "$session_dir" "token_refresher_loop_started" \
    "session=$session" \
    "repo_root=$repo_root"

  while [[ -f "$session_dir/active" ]]; do
    local now expires_epoch wait_seconds
    now=$(garth_now_epoch)
    expires_epoch=$(read_state_value "$session_dir" "token_expires_epoch")
    if [[ -z "$expires_epoch" ]]; then
      sleep_with_session_guard 5 "$session_dir" || break
      continue
    fi

    wait_seconds=$((expires_epoch - now - lead_seconds))
    if ((wait_seconds > 0)); then
      sleep_with_session_guard "$wait_seconds" "$session_dir" || break
    fi

    local success=false
    local attempt_started backoff
    attempt_started=$(garth_now_epoch)
    backoff="$initial_interval_seconds"

    while [[ -f "$session_dir/active" ]]; do
      local token_line
      local token_cmd_rc=0
      if token_line=$("$GARTH_BIN_PATH" token "$repo_root" --machine 2>/dev/null); then
        local token expires_at refreshed_epoch installation_id owner_repo
        IFS=$'\t' read -r token expires_at refreshed_epoch installation_id owner_repo <<< "$token_line"
        garth_write_token_file "$session_dir" "$token" >/dev/null
        write_state_value "$session_dir" "token_expires_at" "$expires_at"
        write_state_value "$session_dir" "token_expires_epoch" "$refreshed_epoch"
        write_state_value "$session_dir" "token_state" "ok"
        garth_audit_log "$session_dir" "token_refresh_success" \
          "session=$session" \
          "owner_repo=$owner_repo" \
          "installation_id=$installation_id" \
          "token=$token" \
          "token_expires_at=$expires_at"
        success=true
        break
      fi
      token_cmd_rc=$?
      garth_audit_log "$session_dir" "token_refresh_failure" \
        "session=$session" \
        "repo_root=$repo_root" \
        "exit_code=$token_cmd_rc"

      local elapsed
      elapsed=$(( $(garth_now_epoch) - attempt_started ))

      if ((retry_window_seconds == 0)); then
        write_state_value "$session_dir" "token_state" "degraded"
        garth_audit_log "$session_dir" "token_refresh_degraded" \
          "session=$session" \
          "state=degraded" \
          "reason=retry_window_disabled"
        break
      fi

      if ((retry_window_seconds != -1 && elapsed >= retry_window_seconds)); then
        write_state_value "$session_dir" "token_state" "degraded"
        garth_audit_log "$session_dir" "token_refresh_degraded" \
          "session=$session" \
          "state=degraded" \
          "reason=retry_window_exceeded"
        break
      fi

      sleep_with_session_guard "$backoff" "$session_dir" || break

      if [[ "$GARTH_TOKEN_REFRESH_RETRY_BACKOFF" == "exponential" ]]; then
        backoff=$((backoff * 2))
        if ((backoff > max_interval_seconds)); then
          backoff="$max_interval_seconds"
        fi
      fi
    done

    if [[ "$success" != "true" ]]; then
      sleep_with_session_guard "$max_interval_seconds" "$session_dir" || break
    fi
  done
  garth_audit_log "$session_dir" "token_refresher_loop_stopped" \
    "session=$session"
}

doctor_try_op_signin() {
  if op whoami >/dev/null 2>&1; then
    return 0
  fi
  if [[ ! -t 0 || ! -t 1 ]]; then
    return 1
  fi
  garth_log_info "1Password CLI session missing; attempting 'eval \"\$(op signin)\"'"
  eval "$(op signin)" >/dev/null 2>&1 || return 1
  op whoami >/dev/null 2>&1
}

cmd_doctor() {
  local repo_dir="."
  local skip_token=false
  local deep_checks=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        repo_dir="$2"
        shift 2
        ;;
      --skip-token)
        skip_token=true
        shift
        ;;
      --deep)
        deep_checks=true
        shift
        ;;
      --help|-h)
        cat << 'HELP'
Usage: garth doctor [--repo <dir>] [--skip-token] [--deep]

Checks:
  - required commands and optional tooling
  - config presence and schema validation
  - GitHub App ref shape + readability
  - GitHub private key PEM validity
  - optional token mint test for a target repo (default: .)
  - default Docker image presence (claude/codex)
  - optional feature checks (packages and mounts)
  - session-layer consistency (state, zellij, containers)
  - with --deep: runtime Docker auth/startup probes for passthrough agents
HELP
        return 0
        ;;
      *)
        garth_die "Unknown option for doctor: $1" 1
        ;;
    esac
  done

  local failures=0
  local warnings=0
  local config_ok=false
  local config_loaded=false
  local op_available=false
  local op_session=false

  garth_log_info "Doctor checks starting"

  local required_cmd
  for required_cmd in git python3; do
    if command -v "$required_cmd" >/dev/null 2>&1; then
      garth_log_success "Required command found: $required_cmd"
    else
      garth_log_error "Missing required command: $required_cmd"
      failures=$((failures + 1))
    fi
  done

  local optional_cmd
  local optional_cmds=(op docker zellij)
  if garth_is_macos; then
    optional_cmds+=(aerospace)
  fi
  for optional_cmd in "${optional_cmds[@]}"; do
    if command -v "$optional_cmd" >/dev/null 2>&1; then
      garth_log_success "Optional command found: $optional_cmd"
      [[ "$optional_cmd" == "op" ]] && op_available=true
    else
      garth_log_warn "Optional command missing: $optional_cmd"
      warnings=$((warnings + 1))
    fi
  done

  if [[ -f "$GARTH_CONFIG_PATH" ]]; then
    garth_log_success "Config exists: $GARTH_CONFIG_PATH"
    config_ok=true
  else
    garth_log_error "Config missing: $GARTH_CONFIG_PATH"
    failures=$((failures + 1))
  fi

  if [[ "$config_ok" == "true" ]]; then
    if garth_python "$GARTH_ROOT/lib/config-parser.py" validate "$GARTH_CONFIG_PATH" >/dev/null; then
      garth_log_success "Config validation passed"
    else
      garth_log_error "Config validation failed"
      failures=$((failures + 1))
    fi

    local env_export
    if env_export=$(config_env 2>/dev/null); then
      eval "$env_export"
      config_loaded=true
      garth_log_success "Config load passed"
    else
      garth_log_error "Config load failed"
      failures=$((failures + 1))
    fi
  fi

  if [[ "$config_loaded" == "true" ]]; then
    if garth_github_app_refs_look_configured; then
      garth_log_success "GitHub App refs look configured"
    else
      garth_log_warn "GitHub App refs look incomplete/placeholders"
      warnings=$((warnings + 1))
    fi

    local defaults_sandbox
    defaults_sandbox="$GARTH_DEFAULTS_SANDBOX"
    csv_to_array "$GARTH_DEFAULTS_AGENTS_CSV"
    local doctor_agent doctor_api_ref
    for doctor_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
      doctor_api_ref=$(garth_agent_field "$doctor_agent" "API_KEY_REF")
      if garth_ref_looks_configured "$doctor_api_ref"; then
        garth_log_success "agents.$doctor_agent.api_key_ref looks configured"
      else
        if [[ "$defaults_sandbox" == "none" ]] || csv_contains_token "$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV" "$doctor_agent"; then
          garth_log_warn "agents.$doctor_agent.api_key_ref is missing or a placeholder: ${doctor_api_ref:-<empty>}"
          garth_log_warn "  Allowed by current defaults because local CLI auth mode is enabled."
          warnings=$((warnings + 1))
        else
          garth_log_error "agents.$doctor_agent.api_key_ref is missing or a placeholder: ${doctor_api_ref:-<empty>}"
          garth_log_error "  Required for defaults.sandbox=docker unless defaults.auth_passthrough includes '$doctor_agent'."
          failures=$((failures + 1))
        fi
      fi
    done
  fi

  if [[ "$op_available" == "true" ]]; then
    if [[ "$config_loaded" == "true" ]] && garth_ref_looks_configured "$GARTH_GITHUB_APP_APP_ID_REF"; then
      if op read "$GARTH_GITHUB_APP_APP_ID_REF" >/dev/null 2>&1; then
        op_session=true
        garth_log_success "1Password CLI session available"
      elif doctor_try_op_signin && op read "$GARTH_GITHUB_APP_APP_ID_REF" >/dev/null 2>&1; then
        op_session=true
        garth_log_success "1Password CLI session available"
      else
        garth_log_warn "1Password CLI is not signed in or cannot read configured refs"
        warnings=$((warnings + 1))
      fi
    else
      if op whoami >/dev/null 2>&1 || doctor_try_op_signin; then
        op_session=true
        garth_log_success "1Password CLI session available"
      else
        garth_log_warn "1Password CLI is not signed in"
        warnings=$((warnings + 1))
      fi
    fi
  fi

  if [[ "$config_loaded" == "true" && "$op_session" == "true" ]]; then
    local app_ref key_ref install_ref
    app_ref="$GARTH_GITHUB_APP_APP_ID_REF"
    key_ref="$GARTH_GITHUB_APP_PRIVATE_KEY_REF"
    install_ref="$GARTH_GITHUB_APP_INSTALLATION_ID_REF"

    if garth_validate_ref_readable "$app_ref"; then
      garth_log_success "Readable app_id_ref"
    else
      garth_log_error "Unreadable app_id_ref: $app_ref"
      failures=$((failures + 1))
    fi

    if garth_validate_ref_readable "$key_ref"; then
      garth_log_success "Readable private_key_ref"
      local tmp_key
      tmp_key=$(mktemp "${TMPDIR:-/tmp}/garth-doctor-key.XXXXXX")
      garth_register_cleanup_path "$tmp_key"
      op read "$key_ref" > "$tmp_key" 2>/dev/null || true
      if ! garth_github_private_key_valid "$tmp_key"; then
        garth_github_normalize_private_key_file "$tmp_key"
      fi
      if garth_github_private_key_valid "$tmp_key"; then
        garth_log_success "GitHub private key PEM is valid"
      else
        garth_log_error "GitHub private key PEM is invalid for ref: $key_ref"
        failures=$((failures + 1))
      fi
    else
      garth_log_error "Unreadable private_key_ref: $key_ref"
      failures=$((failures + 1))
    fi

    if [[ "$GARTH_GITHUB_APP_INSTALLATION_STRATEGY" == "single" ]]; then
      if garth_validate_ref_readable "$install_ref"; then
        garth_log_success "Readable installation_id_ref (single strategy)"
      else
        garth_log_error "Unreadable installation_id_ref: $install_ref"
        failures=$((failures + 1))
      fi
    fi

    csv_to_array "$GARTH_DEFAULTS_AGENTS_CSV"
    local doctor_agent doctor_api_ref
    for doctor_agent in "${_GARTH_ARRAY_OUT[@]:-}"; do
      doctor_api_ref=$(garth_agent_field "$doctor_agent" "API_KEY_REF")
      if garth_ref_looks_configured "$doctor_api_ref"; then
        if garth_validate_ref_readable "$doctor_api_ref"; then
          garth_log_success "Readable agents.$doctor_agent.api_key_ref"
        else
          garth_log_error "Unreadable agents.$doctor_agent.api_key_ref: $doctor_api_ref"
          failures=$((failures + 1))
        fi
      else
        garth_log_info "Skipping agents.$doctor_agent.api_key_ref readability check (placeholder/missing)"
      fi
    done
  fi

  if [[ "$config_loaded" == "true" && -d "$repo_dir" ]]; then
    local repo_root remote_url owner_repo
    if repo_root=$(garth_git_repo_root "$repo_dir" 2>/dev/null); then
      if remote_url=$(garth_git_remote_url "$repo_root" "origin" 2>/dev/null) && \
         owner_repo=$(garth_git_owner_repo_from_remote "$remote_url" 2>/dev/null); then
        garth_log_success "Repo remote parsed: $owner_repo"
        if [[ "$skip_token" == "false" ]]; then
          if [[ "$op_session" == "true" ]]; then
            local token_line
            if token_line=$("$GARTH_BIN_PATH" token "$repo_root" --machine 2>/dev/null); then
              garth_log_success "Token mint test passed"
            else
              garth_log_error "Token mint test failed for repo: $repo_root"
              failures=$((failures + 1))
            fi
          else
            garth_log_warn "Skipping token mint test: 1Password CLI session unavailable"
            warnings=$((warnings + 1))
          fi
        fi
      else
        garth_log_warn "Repo origin is not a supported GitHub URL: $repo_root"
        warnings=$((warnings + 1))
      fi
    else
      garth_log_warn "Not a git repo (token test skipped): $repo_dir"
      warnings=$((warnings + 1))
    fi
  fi

  if [[ "$config_loaded" == "true" ]]; then
    local mount_host _mount_container _mount_mode mount_host_path
    while IFS='|' read -r mount_host _mount_container _mount_mode; do
      [[ -n "$mount_host" ]] || continue
      mount_host_path=$(garth_expand_home_path "$mount_host")
      if [[ -e "$mount_host_path" ]]; then
        garth_log_success "Feature mount source exists: $mount_host_path"
      else
        garth_log_warn "features.mounts source is missing: $mount_host_path"
        warnings=$((warnings + 1))
      fi
    done < <(garth_features_mount_specs_lines 2>/dev/null || true)
  fi

  if [[ "$config_loaded" == "true" ]] && command -v docker >/dev/null 2>&1; then
    local image_prefix image_tag agent state package_name
    image_prefix="$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX"
    for agent in claude codex; do
      image_tag="${image_prefix}-${agent}:latest"
      state=$(garth_docker_image_state "$image_tag")
      case "$state" in
        present)
          garth_log_success "Docker image present: $image_tag"
          while IFS= read -r package_name; do
            [[ -n "$package_name" ]] || continue
            if garth_docker_image_has_feature_package "$image_tag" "$package_name"; then
              garth_log_success "Docker image has feature package '$package_name': $image_tag"
            else
              garth_log_warn "features.packages includes '$package_name' but image lacks it: $image_tag"
              warnings=$((warnings + 1))
            fi
          done < <(garth_features_packages_lines)
          ;;
        missing)
          garth_log_warn "Docker image missing: $image_tag"
          warnings=$((warnings + 1))
          ;;
        unavailable:*)
          garth_log_warn "Could not inspect Docker image $image_tag: ${state#unavailable:}"
          garth_log_warn "Check Docker daemon/context; image presence could not be verified."
          warnings=$((warnings + 1))
          ;;
      esac
    done
  fi

  # Warn if auth mount modes allow containers to overwrite host binaries.
  # See: https://github.com/anthropics/claude-code/issues/29661
  if [[ "$config_loaded" == "true" ]]; then
    local -a rw_warn_mounts=("claude_share" "claude_dot_claude" "claude_config")
    local rw_warn_key rw_warn_mode
    for rw_warn_key in "${rw_warn_mounts[@]}"; do
      rw_warn_mode=$(garth_container_auth_mount_mode "$rw_warn_key" "ro")
      if [[ "$rw_warn_mode" == "rw" ]]; then
        garth_log_warn "security.auth_mount_mode.$rw_warn_key is 'rw' — container may overwrite host files (see issue #29661)"
        warnings=$((warnings + 1))
      fi
    done
  fi

  if [[ "$deep_checks" == "true" ]]; then
    if [[ "$config_loaded" != "true" ]]; then
      garth_log_warn "Skipping deep checks: config did not load"
      warnings=$((warnings + 1))
    elif ! command -v docker >/dev/null 2>&1; then
      garth_log_warn "Skipping deep checks: docker command is unavailable"
      warnings=$((warnings + 1))
    else
      local deep_image_prefix
      deep_image_prefix="$GARTH_DEFAULTS_DOCKER_IMAGE_PREFIX"

      if csv_contains_token "$GARTH_DEFAULTS_AUTH_PASSTHROUGH_CSV" "claude"; then
        local claude_image
        claude_image="${deep_image_prefix}-claude:latest"
        local claude_state
        claude_state=$(garth_docker_image_state "$claude_image")
        if [[ "$claude_state" != "present" ]]; then
          garth_log_warn "Skipping Claude deep checks: Docker image unavailable: $claude_image ($claude_state)"
          warnings=$((warnings + 1))
        else
          garth_log_info "Deep check: probing Claude Docker auth/startup path"
          local -a claude_mount_args=()
          local mount_arg
          while IFS= read -r mount_arg; do
            claude_mount_args+=("$mount_arg")
          done < <(garth_container_emit_auth_mounts_lines "claude" || true)

          if [[ ${#claude_mount_args[@]} -eq 0 ]]; then
            garth_log_warn "Skipping Claude deep checks: no passthrough mount paths found"
            warnings=$((warnings + 1))
          else
            local preamble preamble_escaped auth_status_json state_probe_json
            preamble=$(garth_claude_runtime_preamble)
            printf -v preamble_escaped '%q' "$preamble"

            if auth_status_json=$(docker run --rm \
              --read-only \
              --tmpfs /tmp:rw,noexec,nosuid,size=256m \
              --tmpfs /home/agent:rw,exec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.cache:rw,noexec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.local:rw,exec,nosuid,size=256m,uid=1001,gid=1001,mode=0700 \
              "${claude_mount_args[@]}" \
              --env HOME=/home/agent \
              --env XDG_CACHE_HOME=/home/agent/.cache \
              --env XDG_CONFIG_HOME=/home/agent/.config \
              --env XDG_STATE_HOME=/home/agent/.local/state \
              --env PATH=/home/agent/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
              "$claude_image" \
              bash -lc "eval ${preamble_escaped}; claude auth status" 2>/dev/null); then
              if printf '%s\n' "$auth_status_json" | grep -Eq '"loggedIn"[[:space:]]*:[[:space:]]*true'; then
                garth_log_success "Deep check passed: Claude auth status is logged in in container"
              else
                garth_log_error "Deep check failed: Claude auth status did not report logged in"
                failures=$((failures + 1))
              fi
            else
              garth_log_error "Deep check failed: unable to execute 'claude auth status' in container"
              failures=$((failures + 1))
            fi

            if state_probe_json=$(docker run --rm \
              --read-only \
              --tmpfs /tmp:rw,noexec,nosuid,size=256m \
              --tmpfs /home/agent:rw,exec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.cache:rw,noexec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.local:rw,exec,nosuid,size=256m,uid=1001,gid=1001,mode=0700 \
              "${claude_mount_args[@]}" \
              --env HOME=/home/agent \
              --env XDG_CACHE_HOME=/home/agent/.cache \
              --env XDG_CONFIG_HOME=/home/agent/.config \
              --env XDG_STATE_HOME=/home/agent/.local/state \
              --env PATH=/home/agent/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
              "$claude_image" \
              bash -lc "eval ${preamble_escaped}; jq -c '{has_oauth: (.oauthAccount | type == \"object\"), has_first_start: has(\"firstStartTime\")}' /home/agent/.claude.json" 2>/dev/null); then
              if printf '%s\n' "$state_probe_json" | grep -Eq '"has_oauth":[[:space:]]*true' && \
                 printf '%s\n' "$state_probe_json" | grep -Eq '"has_first_start":[[:space:]]*true'; then
                garth_log_success "Deep check passed: Claude state file has oauth + firstStartTime"
              else
                garth_log_error "Deep check failed: Claude state file is missing oauth or firstStartTime"
                failures=$((failures + 1))
              fi
            else
              garth_log_error "Deep check failed: unable to inspect /home/agent/.claude.json in container"
              failures=$((failures + 1))
            fi

            local probe_name
            probe_name="garth-doctor-claude-probe-$$-$(garth_now_epoch)"
            if docker run -d --name "$probe_name" -it \
              --read-only \
              --tmpfs /tmp:rw,noexec,nosuid,size=256m \
              --tmpfs /home/agent:rw,exec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.cache:rw,noexec,nosuid,size=1024m,uid=1001,gid=1001,mode=0700 \
              --tmpfs /home/agent/.local:rw,exec,nosuid,size=256m,uid=1001,gid=1001,mode=0700 \
              "${claude_mount_args[@]}" \
              --env HOME=/home/agent \
              --env XDG_CACHE_HOME=/home/agent/.cache \
              --env XDG_CONFIG_HOME=/home/agent/.config \
              --env XDG_STATE_HOME=/home/agent/.local/state \
              --env PATH=/home/agent/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
              "$claude_image" \
              bash -lc "eval ${preamble_escaped}; claude" >/dev/null 2>&1; then
              sleep 5
              local probe_logs probe_logs_plain probe_logs_compact
              probe_logs=$(docker logs --tail 220 "$probe_name" 2>&1 || true)
              probe_logs_plain=$(printf '%s\n' "$probe_logs" | sed -E $'s/\x1B\\[[0-9;?]*[ -/]*[@-~]//g; s/\r//g')
              probe_logs_compact=$(printf '%s\n' "$probe_logs_plain" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]\n')
              if printf '%s\n' "$probe_logs_compact" | grep -Eq 'selectloginmethod|openingbrowsertosignin|choosethetextstyle|letsgetstarted|accessingworkspace|yesitrustthisfolder'; then
                garth_log_error "Deep check failed: Claude startup entered onboarding/login/trust flow"
                failures=$((failures + 1))
              elif printf '%s\n' "$probe_logs_compact" | grep -Eq 'installmethodisnative|nativeinstallationexistsbut'; then
                garth_log_error "Deep check failed: Claude startup reported native install layout mismatch"
                failures=$((failures + 1))
              else
                garth_log_success "Deep check passed: Claude startup avoided onboarding/login/trust/install prompts"
              fi
              docker rm -f "$probe_name" >/dev/null 2>&1 || true
            else
              garth_log_warn "Deep check skipped: unable to start interactive Claude probe container"
              warnings=$((warnings + 1))
            fi
          fi
        fi
      else
        garth_log_info "Skipping Claude deep checks: 'claude' not enabled in defaults.auth_passthrough"
      fi
    fi
  fi

  ensure_state_root
  local -a doctor_session_dirs=()
  local doctor_dir
  while IFS= read -r doctor_dir; do
    [[ -n "$doctor_dir" ]] || continue
    doctor_session_dirs+=("$doctor_dir")
  done < <(garth_session_list_dirs)

  local known_session_names=$'\n'
  for doctor_dir in "${doctor_session_dirs[@]}"; do
    known_session_names+=$(garth_session_name_for_dir "$doctor_dir")
    known_session_names+=$'\n'
  done

  local -a degraded_session_dirs=()
  local -a stale_state_dirs=()
  for doctor_dir in "${doctor_session_dirs[@]}"; do
    local doctor_status_line doctor_status
    doctor_status_line=$(garth_session_status_line "$doctor_dir")
    doctor_status="${doctor_status_line#*$'\t'}"
    if [[ "$doctor_status" == degraded* ]]; then
      degraded_session_dirs+=("$doctor_dir")
      garth_log_warn "Degraded session: $(garth_session_name_for_dir "$doctor_dir") ($(garth_session_id_for_dir "$doctor_dir")) - $doctor_status"
      warnings=$((warnings + 1))
    fi

    local doctor_session_name doctor_active doctor_stopped doctor_containers_all doctor_zellij_state
    doctor_session_name=$(garth_session_name_for_dir "$doctor_dir")
    doctor_active="false"
    [[ -f "$doctor_dir/active" ]] && doctor_active="true"
    doctor_stopped="false"
    [[ -f "$doctor_dir/stopped_epoch" ]] && doctor_stopped="true"
    doctor_containers_all=$(count_session_containers_all "$doctor_session_name")
    doctor_zellij_state=$(garth_zellij_session_state "$doctor_session_name")
    if [[ "$doctor_active" != "true" && "$doctor_stopped" != "true" && "$doctor_zellij_state" == "missing" && "$doctor_containers_all" -eq 0 ]]; then
      stale_state_dirs+=("$doctor_dir")
      garth_log_warn "Stale session state directory: $doctor_dir"
      warnings=$((warnings + 1))
    fi
  done

  local -a orphan_zellij_sessions=()
  if command -v zellij >/dev/null 2>&1; then
    local zj
    while IFS= read -r zj; do
      [[ -n "$zj" ]] || continue
      if [[ "$known_session_names" != *$'\n'"$zj"$'\n'* ]]; then
        orphan_zellij_sessions+=("$zj")
        garth_log_warn "Orphan zellij session (no state dir): $zj"
        warnings=$((warnings + 1))
      fi
    done < <(garth_zellij_list_sessions)
  fi

  local -a orphan_container_ids=()
  local -a orphan_container_sessions=()
  if command -v docker >/dev/null 2>&1; then
    local cid csess
    while IFS= read -r cid; do
      [[ -n "$cid" ]] || continue
      csess=$(docker inspect -f '{{ index .Config.Labels "garth.session" }}' "$cid" 2>/dev/null || true)
      [[ -n "$csess" ]] || continue
      if [[ "$known_session_names" != *$'\n'"$csess"$'\n'* ]]; then
        orphan_container_ids+=("$cid")
        orphan_container_sessions+=("$csess")
        garth_log_warn "Orphan container (no state dir): $cid (session=$csess)"
        warnings=$((warnings + 1))
      fi
    done < <(docker ps -aq --filter label=garth.session)
  fi

  local can_prompt_cleanup=false
  if garth_has_tty; then
    can_prompt_cleanup=true
  fi

  if [[ "$can_prompt_cleanup" == "true" ]]; then
    if [[ ${#degraded_session_dirs[@]} -gt 0 ]]; then
      if garth_ask_yn "Stop degraded sessions now?"; then
        for doctor_dir in "${degraded_session_dirs[@]}"; do
          stop_session_by_dir "$doctor_dir"
        done
      fi
    fi

    if [[ ${#orphan_zellij_sessions[@]} -gt 0 ]]; then
      if garth_ask_yn "Delete orphan zellij sessions now?"; then
        local orphan_zj
        for orphan_zj in "${orphan_zellij_sessions[@]}"; do
          garth_zellij_kill_session "$orphan_zj"
        done
      fi
    fi

    if [[ ${#orphan_container_ids[@]} -gt 0 ]]; then
      if garth_ask_yn "Remove orphan containers now?"; then
        local orphan_cid
        for orphan_cid in "${orphan_container_ids[@]}"; do
          docker rm -f "$orphan_cid" >/dev/null 2>&1 || true
        done
      fi
    fi

    if [[ ${#stale_state_dirs[@]} -gt 0 ]]; then
      if garth_ask_yn "Delete stale session state directories now?"; then
        for doctor_dir in "${stale_state_dirs[@]}"; do
          rm -rf "$doctor_dir"
        done
      fi
    fi
  elif [[ ${#degraded_session_dirs[@]} -gt 0 || ${#orphan_zellij_sessions[@]} -gt 0 || ${#orphan_container_ids[@]} -gt 0 || ${#stale_state_dirs[@]} -gt 0 ]]; then
    garth_log_warn "Cleanup actions skipped (no interactive terminal)."
  fi

  if ((failures > 0)); then
    garth_log_error "Doctor found ${failures} failing check(s) and ${warnings} warning(s)"
    return 1
  fi

  if ((warnings > 0)); then
    garth_log_warn "Doctor found 0 failures and ${warnings} warning(s)"
  else
    garth_log_success "Doctor found 0 failures and 0 warnings"
  fi
  return 0
}

main() {
  local command="${1:-}"
  if [[ -z "$command" ]]; then
    usage
    exit 1
  fi
  shift || true

  case "$command" in
    --version|version)
      cat "$GARTH_ROOT/VERSION" 2>/dev/null || echo "unknown"
      ;;
    new) cmd_new "$@" ;;
    open) cmd_open "$@" ;;
    up) cmd_up "$@" ;;
    ps) cmd_ps "$@" ;;
    containers) cmd_containers "$@" ;;
    down) cmd_down "$@" ;;
    agent) cmd_agent "$@" ;;
    refresh-images|refresh) cmd_refresh_images "$@" ;;
    token) cmd_token "$@" ;;
    doctor) cmd_doctor "$@" ;;
    stop) cmd_stop "$@" ;;
    setup) cmd_setup "$@" ;;
    internal-refresh) cmd_internal_refresh "$@" ;;
    --help|-h|help) usage ;;
    *)
      garth_die "Unknown command: $command" 1
      ;;
  esac
}

main "$@"
